# Returns 0 on confirm (datum set), 1 on ESC/back.
_wiz_disk() {
	velo_clear
	_wd_disks=$(velo_list_disks)
	if [ -z "$_wd_disks" ]; then
		tui_msgbox "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" "No disks" \
			"No sd*/wd* disks were detected." \
			"Set VELO_FAKE_DISKS to test on this host." \
			"(e.g. VELO_FAKE_DISKS=sd0:abc,wd1:def)"
		return 1
	fi
	# Cap to what fits the viewport (M1 req §2: widgets do not scroll).  A real
	# machine shows a handful; if ever more, show the first N and WARN to stderr
	# (no SILENT truncation) so the operator knows others exist.
	#
	# Each disk is enriched to a name·size·type·DUID row (+ [MOUNTED]/[media?]
	# markers) so the operator never picks a bare sdN.  Each ROW is passed as ONE
	# menu item via `set --` accumulation (NOT word-split -- the row has spaces);
	# a PARALLEL plain-name list (_wd_names, safe to word-split) maps the chosen
	# index back to a disk name through the existing idx_from_list.
	_wd_max=12
	_wd_names=""
	_wd_n=0
	_wd_total=0
	set --
	for _wd_d in $_wd_disks; do
		_wd_total=$((_wd_total + 1))
		if [ "$_wd_n" -ge "$_wd_max" ]; then continue; fi
		_wd_names="$_wd_names $_wd_d"
		set -- "$@" "$(velo_disk_row "$_wd_d")"
		_wd_n=$((_wd_n + 1))
	done
	if [ "$_wd_total" -gt "$_wd_max" ]; then
		echo "velo: $_wd_total disks detected; showing first $_wd_max." \
		     "Target others from the (S)hell." >&2
	fi
	_wiz_help "back" "sizes"
	tui_menu "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" "Step 1/$_wz_total: Root disk" "$@" || return 1
	_wd_name=$(idx_from_list "$VELO_MENU_INDEX" $_wd_names) || return 1
	is_valid_disk "$_wd_name" || return 1
	VELO_S_DISK=$_wd_name
	return 0
}

# Returns 0 on confirm, 1 on ESC/back.
_wiz_encrypt() {
	velo_clear
	_wiz_help "back"
	tui_radio "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" "Step 2/$_wz_total: Encrypt root disk (softraid CRYPTO)?" \
		"no  -- plaintext install" \
		"yes -- full-disk encryption (passphrase)" || return 1
	if [ "$VELO_RADIO_INDEX" = 1 ]; then
		VELO_S_ENCRYPT="yes"
		# confirm-twice passphrase loop (M1 req §1): re-loop on mismatch/empty.
		while :; do
			velo_clear
			tui_box "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" 6 "Passphrase"
			# Unified footer (mirror rootpw/userpw): the velo_clear above wipes the
			# radio screen's help-line, so redraw it INSIDE the loop -- this keeps
			# the hint on the passphrase entry AND on the re-looped Mismatch box.
			_wiz_help "back"
			tui_password $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 2)) $((VELO_BOX_W - 4)) "passphrase:" \
				|| { VELO_S_ENCRYPT="no"; return 1; }
			_wz_p1=$VELO_PASSWORD; VELO_PASSWORD=""
			tui_password $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 3)) $((VELO_BOX_W - 4)) "again:     " \
				|| { _wz_p1=""; VELO_S_ENCRYPT="no"; return 1; }
			_wz_p2=$VELO_PASSWORD; VELO_PASSWORD=""
			if [ -n "$_wz_p1" ] && [ "$_wz_p1" = "$_wz_p2" ]; then
				VELO_S_PASSPHRASE=$_wz_p1
				_wz_p1=""; _wz_p2=""
				break
			fi
			_wz_p1=""; _wz_p2=""
			tui_msgbox "$VELO_BOX_X" $((VELO_BOX_Y + 5)) "$VELO_BOX_W" "Mismatch" \
				"Passphrases differ or were empty -- try again."
		done
	else
		VELO_S_ENCRYPT="no"
		VELO_S_PASSPHRASE=""
		# Reset the FDE-only boot-mode datum too: turning encryption OFF (incl.
		# after ESC-walking back from the bootmode screen) must not leave a stale
		# 'bios'/'uefi' from an abandoned encrypted path lingering in state.
		VELO_S_BOOTMODE="same"
	fi
	return 0
}

