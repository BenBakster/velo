# valid_wifi_value VALUE -- a Wi-Fi SSID or WPA key safe to splice into BOTH the
# single-line `join "..." wpakey "..."` hostname.iwm0 directive AND the key=value
# answers file: non-empty, no double-quote / backslash (would break the quoted
# directive), and no embedded newline (would split the line and inject a second
# ifconfig directive / answers key).  Mirrors is_valid_disk / valid_hostname so a
# hostile or env-pre-seeded value cannot escape its field.
valid_wifi_value() {
	_vwv=$1
	[ -n "$_vwv" ] || return 1
	case "$_vwv" in
	*'"'*|*'\'*) return 1 ;;
	esac
	# A literal newline in the pattern catches a value carrying an embedded LF.
	case "$_vwv" in
	*'
'*) return 1 ;;
	esac
	return 0
}

# velo_answers_body -- emit the schema-1 answers contract (m2-design s2.3) on
# stdout: the key=value lines install.site.velo reads to apply the operator's
# profile/level.  PURE (no /mnt, no side effects), so it is unit-testable and
# velo_execute just redirects it into /mnt/etc/velo/answers.  Defence-in-depth:
# wifi_ssid is re-checked with valid_wifi_value HERE too -- the _wiz_wifi guard
# only covers the interactive path, so an env-pre-seeded VELO_S_WIFI_SSID with an
# embedded newline must not split this file (a bad/empty value collapses to the
# blank "wifi_ssid=" line, never an injected directive).  The plaintext WPA PSK
# is NEVER emitted here -- it goes only to hostname.iwm0.
velo_answers_body() {
	_putln "schema=1"
	_putln "profile=$VELO_S_PROFILE"
	_putln "startmode=$VELO_S_STARTMODE"
	_putln "pkgs=$VELO_S_PKGS"
	_putln "hostname=$VELO_S_HOSTNAME"
	_putln "encrypt=$VELO_S_ENCRYPT"
	if valid_wifi_value "$VELO_S_WIFI_SSID"; then
		_putln "wifi_ssid=$VELO_S_WIFI_SSID"
	else
		_putln "wifi_ssid="
	fi
}

# Returns 0 on confirm/skip, 1 on ESC/back.  Optional screen: blank SSID skips
# Wi-Fi setup entirely (the template hostname.iwm0 ships without credentials).
# When SSID is provided, PSK is required; both are written directly to
# /mnt/etc/hostname.iwm0 by velo_execute -- the PSK never lands in the answers
# audit file.  PSK is scrubbed with the other secrets after execute.
_wiz_wifi() {
	velo_clear
	tui_box "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" 6 "Step 6/$_wz_total: Wi-Fi (optional)"
	_wiz_help "back"
	while :; do
		tui_input $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 2)) $((VELO_BOX_W - 4)) \
			"SSID (blank = skip):" "${VELO_S_WIFI_SSID:-}" || return 1
		_ww_ssid=$VELO_INPUT
		if [ -z "$_ww_ssid" ]; then
			VELO_S_WIFI_SSID=""; VELO_S_WIFI_PSK=""; _ww_ssid=""; return 0
		fi
		if ! valid_wifi_value "$_ww_ssid"; then
			tui_msgbox "$VELO_BOX_X" $((VELO_BOX_Y + 5)) "$VELO_BOX_W" "Invalid SSID" \
				"No double-quotes, backslashes or newlines in SSID."
			_ww_ssid=""; continue
		fi
		tui_password $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 3)) $((VELO_BOX_W - 4)) \
			"WPA key:            " || return 1
		_ww_psk=$VELO_PASSWORD; VELO_PASSWORD=""
		if [ -z "$_ww_psk" ]; then
			tui_msgbox "$VELO_BOX_X" $((VELO_BOX_Y + 5)) "$VELO_BOX_W" "Required" \
				"WPA key cannot be empty."
			_ww_ssid=""; _ww_psk=""; continue
		fi
		if ! valid_wifi_value "$_ww_psk"; then
			tui_msgbox "$VELO_BOX_X" $((VELO_BOX_Y + 5)) "$VELO_BOX_W" "Invalid key" \
				"No double-quotes, backslashes or newlines in WPA key."
			_ww_ssid=""; _ww_psk=""; continue
		fi
		VELO_S_WIFI_SSID=$_ww_ssid; VELO_S_WIFI_PSK=$_ww_psk
		_ww_ssid=""; _ww_psk=""; return 0
	done
}

