#!/bin/ksh
# velo-install -- the velo OpenBSD 7.9 install wizard (M1, DRY-RUN).
#
# Target shell:  OpenBSD /bin/ksh (pdksh / oksh) inside the bsd.rd install
#                ramdisk.  Also runs UNMODIFIED under bash >= 3 on a
#                Void/Linux host for dry-run demos and CI.
#
# =========================================================================
#  ABSOLUTE SAFETY RULE -- M1 IS DRY-RUN.
#  This program WRITES NOTHING to any disk and NEVER executes
#  fdisk / disklabel / bioctl / newfs / dd.  It only PRINTS the planned
#  shell commands and the generated install.conf.  The destructive path is
#  a later milestone (M3/M4), gated behind the summary screen (Ворота-СТОП).
#  Every fdisk/disklabel/bioctl/newfs/dd token in this file lives INSIDE a
#  printed heredoc/_putln string -- never on a command line that the shell
#  would execute.  grep-prove: see tests/velo-install-test.ksh.
# =========================================================================
#
#  Modes (dispatch on $1, mirrors the demo's screenshot|interactive split):
#    velo-install            interactive wizard, 8 screens + summary (+ a 9th,
#                            boot-mode, shown only for an encrypted install)
#    velo-install plan       NON-INTERACTIVE dry-run: read state from env,
#                            print install.conf + crypto plan, exit. No tty,
#                            no raw mode, no key reads. CI/test path.
#    velo-install selftest   run the pure-function assertions; PASS/FAIL.
#
#  Source-time: locate and source the TUI library relative to THIS script.
#  `dirname` is NOT in the install ramdisk, so derive the dir with parameter
#  expansion only (same pattern as demo/tui-demo.ksh).

case "$0" in
*/*) VELO_HERE=${0%/*} ;;   # strip trailing /name
*)   VELO_HERE=. ;;         # no slash -> current dir
esac
# Source the TUI library.  By default it lives at the repo-relative path (host
# demos, CI, tests -- unchanged M1 behaviour).  In the patched bsd.rd ramdisk
# both velo files are injected at '/', so the repo-relative path does not exist;
# the ramdisk launcher /velo-rd-hook.sh exports VELO_TUI=/velo-tui.ksh and we
# honour that override.  One env seam, no test breakage (VELO_TUI unset on the
# host -> the original path).  (docs/m3-design.md s2.3.)
: "${VELO_TUI:=$VELO_HERE/../src/velo-tui.ksh}"
. "$VELO_TUI"

# ===========================================================================
#  STATE  (flat VELO_S_* scalars -- pdksh-portable; one datum per screen)
#  These default-preserving assignments (${VAR:-default}) let the `plan`
#  entrypoint seed state from same-named ENV vars (design §6) while the
#  interactive wizard, run with no such env, still starts from the empty
#  defaults. velo_plan re-validates every value, so a hostile env cannot
#  inject anything.
# ===========================================================================
VELO_S_DISK=${VELO_S_DISK:-""}            # raw device, validated ^sd|wd  (screen 1)
VELO_S_ENCRYPT=${VELO_S_ENCRYPT:-no}      # yes|no                        (screen 2)
VELO_S_PASSPHRASE=${VELO_S_PASSPHRASE:-""} # secret; lives ONLY here; cleared after
VELO_S_HOSTNAME=${VELO_S_HOSTNAME:-""}    # RFC-1123 label                (screen 3)
VELO_S_PROFILE=${VELO_S_PROFILE:-""}      # homely|minimal|fortress       (screen 4)
VELO_S_PKGS=${VELO_S_PKGS:-""}            # space-separated package names (screen 5)
VELO_S_STARTMODE=${VELO_S_STARTMODE:-""}  # L1|L2|L3                      (screen 6)
VELO_S_BOOTMODE=${VELO_S_BOOTMODE:-same}  # same|uefi|bios target firmware (screen 8b, FDE only)
VELO_S_ROOTDISK=${VELO_S_ROOTDISK:-""}    # disk install.conf targets (derived §5)
# --- install-MEDIUM location (the disk/partition/path the SETS live on) -------
# These answer the FOUR install.sub prompts that follow "Location of sets = disk"
# (the 2026-06-08 Fujitsu failure: those prompts were unanswered, so autoinstall
# took the WRONG defaults sd0/i/7.9-amd64 and aborted "7.9/amd64 does not exist").
# MEDIADISK is DERIVED at run time by velo_find_media_disk -- the sd-unit of the
# velo USB is enumeration-order-dependent and must NEVER be hardcoded.  PART/PATH
# are constants matching build/grow-media.sh (sets at 4.2BSD 'a':/7.9/amd64),
# env-seedable so a build that overrides SETS_PART can override these in lockstep.
VELO_S_MEDIADISK=${VELO_S_MEDIADISK:-""}          # velo USB sd-unit (detected in velo_execute)
VELO_S_MEDIAPART=${VELO_S_MEDIAPART:-a}           # disklabel partition carrying the sets
VELO_S_MEDIAPATH=${VELO_S_MEDIAPATH:-7.9/amd64}   # set-tree path on that partition
VELO_S_ROOTPW=${VELO_S_ROOTPW:-""}        # secret: root account password   (screen 3)
VELO_S_USERPW=${VELO_S_USERPW:-""}        # secret: anon account password   (screen 4)
VELO_S_WIFI_SSID=${VELO_S_WIFI_SSID:-""} # Wi-Fi network name (optional)   (screen 6)
VELO_S_WIFI_PSK=${VELO_S_WIFI_PSK:-""}   # secret: WPA key; cleared after execute
# Internal bcrypt hashes -- deliberately NOT env-seedable (no ${VAR:-} seam):
# they are computed ONLY inside velo_execute, from the plaintext above, via
# encrypt(1).  Empty -> gen_install_conf emits the <bcrypt-hash> placeholder, so
# the DRY-RUN/`plan`/on-screen-preview paths NEVER carry a real credential.
VELO_S_ROOTPW_HASH=""                     # set ONLY inside velo_execute
VELO_S_USERPW_HASH=""                     # set ONLY inside velo_execute

# Stable, ordered option lists.  These are the single source of truth for
# both the menus AND the idx_to_* mappers, so the displayed order and the
# re-indexed value can never diverge (M1 req §3).
VELO_PROFILES="homely minimal fortress"   # homely first = default desktop
VELO_STARTMODES="L1 L2 L3"                  # L1 first = permissive baseline
VELO_BOOTMODES="same uefi bios hybrid"       # same first = auto-detect (safe default)

# ===========================================================================
#  PURE / TESTABLE FUNCTIONS
#  Each takes args and echoes a result or sets ONE documented out-global.
#  None touch a tty; none write to disk.  Reusable under bash AND oksh.
# ===========================================================================

# --- is_valid_disk NAME : whitelist predicate (exit status only) -----------
# Accepts ^sd[0-9]+$ or ^wd[0-9]+$ ; rejects everything else (cd*, empty,
# trailing junk, shell metachars).
#
# Implemented WITHOUT ksh extended globs (+([0-9])): those would force the
# caller to `shopt -s extglob` under bash, which `bash -n` (parse-only, never
# runs the shopt) cannot honour -> a spurious "syntax error" at lint time. The
# prefix-strip + digit-only check below parses and runs identically under
# `bash -n`, runtime bash, and OpenBSD oksh -- no extglob, no anchoring tricks.
is_valid_disk() {
	case "$1" in
	sd?*|wd?*) : ;;            # must start sd/wd and have >=1 more char
	*) return 1 ;;
	esac
	_ivd_tail=${1#??}          # strip the 2-char sd/wd prefix
	# tail must be all digits and non-empty (rejects sd0x, sd0a, sd0;rm, etc.)
	case "$_ivd_tail" in
	''|*[!0-9]*) return 1 ;;
	esac
	return 0
}

# --- velo_list_disks : INJECTABLE disk detection ---------------------------
# Prints whitelisted disk names, one per line, order preserved.
# Source of truth on OpenBSD: `sysctl -n hw.disknames` (format
# "name:DUID,name:DUID,...", DUID may be empty, e.g. "sd0:4b84,cd0:,wd0").
# Injection for host testing/CI: if VELO_FAKE_DISKS is set, use its value
# verbatim instead of sysctl, so this runs on the Void host (no OpenBSD).
velo_list_disks() {
	_vld_raw=""
	if [ -n "${VELO_FAKE_DISKS+x}" ]; then
		_vld_raw=$VELO_FAKE_DISKS
	else
		_vld_raw=$(sysctl -n hw.disknames 2>/dev/null)
	fi
	# Split on ',' with IFS (no tr/awk in the ramdisk), strip ":DUID" suffix,
	# keep only whitelisted names.  Reuse is_valid_disk so detection and
	# validation cannot diverge.
	_vld_oifs=$IFS
	IFS=','
	set -- $_vld_raw
	IFS=$_vld_oifs
	for _vld_tok in "$@"; do
		_vld_name=${_vld_tok%%:*}
		if is_valid_disk "$_vld_name"; then
			_putln "$_vld_name"
		fi
	done
}

# --- idx_from_list INDEX WORD... : 0-based positional lookup ---------------
# Echoes the (INDEX+1)-th positional WORD; empty + nonzero if out of range.
# This is the generic helper behind idx_to_disk/profile/startmode (M1 req §3).
idx_from_list() {
	_ifl_i=$1
	shift
	# reject non-numeric / negative indices
	case "$_ifl_i" in
	''|*[!0-9]*) return 1 ;;
	esac
	if [ "$_ifl_i" -ge "$#" ]; then
		return 1
	fi
	_ifl_n=$((_ifl_i + 1))
	eval "_ifl_v=\${$_ifl_n}"
	_put "$_ifl_v"
	return 0
}

# --- idx_to_disk INDEX : map a menu index back to a detected disk name -----
idx_to_disk() {
	idx_from_list "$1" $(velo_list_disks)
}

# --- idx_to_profile INDEX --------------------------------------------------
idx_to_profile() {
	idx_from_list "$1" $VELO_PROFILES
}

# --- idx_to_startmode INDEX ------------------------------------------------
idx_to_startmode() {
	idx_from_list "$1" $VELO_STARTMODES
}

# --- idx_to_bootmode INDEX -------------------------------------------------
idx_to_bootmode() {
	idx_from_list "$1" $VELO_BOOTMODES
}

# --- idxset_to_pkgs "IDX IDX ..." WORD... ----------------------------------
# Maps a space-separated checked-index list (VELO_CHECKED) back to the
# package names in the same positional universe.  Echoes a space-joined list.
idxset_to_pkgs() {
	_isp_idxset=$1
	shift
	_isp_out=""
	for _isp_i in $_isp_idxset; do
		case "$_isp_i" in
		''|*[!0-9]*) continue ;;
		esac
		_isp_name=$(idx_from_list "$_isp_i" "$@") || continue
		if [ -n "$_isp_name" ]; then
			if [ -n "$_isp_out" ]; then
				_isp_out="$_isp_out $_isp_name"
			else
				_isp_out="$_isp_name"
			fi
		fi
	done
	_put "$_isp_out"
}

# --- valid_hostname NAME : RFC-1123 label predicate ------------------------
# 1..63 chars from [A-Za-z0-9-], no leading/trailing '-', no dots/spaces/
# metachars.  Pure case globs; exit status only.
valid_hostname() {
	_vh=$1
	# length 1..63
	[ -n "$_vh" ] || return 1
	[ "${#_vh}" -le 63 ] || return 1
	# no leading or trailing hyphen
	case "$_vh" in
	-*|*-) return 1 ;;
	esac
	# only the allowed charset (reject if any char is NOT [A-Za-z0-9-])
	case "$_vh" in
	*[!A-Za-z0-9-]*) return 1 ;;
	esac
	return 0
}

# --- profile_pkgs PROFILE : checklist universe for a profile (data table) --
# Returns the package universe shown on screen 5 (all start unchecked per
# M1 req §4).  Single source of truth; unknown profile -> empty + nonzero.
# Packages are NOT written to install.conf (OpenBSD installs pkgs post-reboot)
# -- they are recorded for M2's pkg_add list and printed in the plan.
profile_pkgs() {
	case "$1" in
	minimal)  _put "git curl nano" ;;
	homely)   _put "openbox tint2 terminator firefox git curl nano noto-fonts thunar mpv" ;;
	fortress) _put "tor torsocks wireguard-tools gnupg pwgen git nano" ;;
	*) return 1 ;;
	esac
	return 0
}

# --- boot-mode: detect / resolve / fdisk args ------------------------------
# velo installs onto a DEDICATED disk and must lay it out to match the firmware
# the target machine boots under: GPT + EFI System Partition for UEFI, a plain
# MBR (single active 0xA6 OpenBSD partition) for legacy BIOS.  This matters
# because a GPT disk does NOT boot under legacy SeaBIOS ("No active partition"),
# while a plain MBR boots under both.  Three states (VELO_S_BOOTMODE):
#   same  -> auto-detect from the running installer's own firmware (default)
#   uefi  -> force GPT + EFI system partition
#   bios  -> force legacy MBR
# Detection keys on the reliable UEFI markers efi0/efifb0 -- NOT the ACPI
# version: `acpi0 at bios0` appears under BOTH modes and the version digit does
# not track firmware (verified against real dmesg: VirtualBox UEFI reports ACPI
# 4.0, QEMU/SeaBIOS reports ACPI 1.0; modern legacy hardware can report ACPI 5+
# -> an `ACPI [5-9]` test both false-negates real UEFI and false-positives
# legacy).  Sources: efi(4) "efi* at bios?", efifb(4) "efifb* at mainbus?",
# fdisk(8), FAQ 14 (softraid crypto), distrib/amd64/common/install.md.

# velo_detect_bootmode -- echo uefi|bios|unknown for the CURRENT machine.
# Reads the boot dmesg (/var/run/dmesg.boot, the stable single-pass file
# install.md keys on; falls back to the live `dmesg`).  When neither is
# available or no amd64 firmware line is present (host, tests, non-OpenBSD) it
# returns "unknown" so callers never guess.  VELO_BOOTMODE_DETECT overrides the
# whole probe for host tests.
velo_detect_bootmode() {
	if [ -n "${VELO_BOOTMODE_DETECT:-}" ]; then
		_put "$VELO_BOOTMODE_DETECT"; return 0
	fi
	if [ -r /var/run/dmesg.boot ]; then
		_vdb=$(cat /var/run/dmesg.boot 2>/dev/null)
	elif command -v dmesg >/dev/null 2>&1; then
		_vdb=$(dmesg 2>/dev/null)
	else
		_vdb=""
	fi
	[ -n "$_vdb" ] || { _put unknown; return 0; }
	# UEFI iff an EFI device attached (efi0 most robust -- present even on
	# headless VMs where efifb0 fails); legacy iff the BIOS line is present and
	# no EFI; neither -> unknown.  Anchored to line start (^) to avoid matching a
	# stray substring in some later log/comment line.
	if _put "$_vdb" | grep -q -e '^efi0 at bios0: UEFI' -e '^efifb0 at mainbus0'; then
		_put uefi
	elif _put "$_vdb" | grep -q '^bios0 at mainbus0'; then
		_put bios
	else
		_put unknown
	fi
}

# velo_resolve_bootmode -- echo the EFFECTIVE uefi|bios for this install.  An
# explicit uefi|bios state is honoured verbatim; `same` auto-detects.  When
# `same` cannot be resolved it echoes "unknown" and returns nonzero -- callers
# decide: plan_crypto (DRY-RUN preview) shows a documented default, while the
# REAL velo_run_crypto refuses (fail-safe STOP -- never guess on real hardware).
velo_resolve_bootmode() {
	case "$VELO_S_BOOTMODE" in
	uefi|bios|hybrid) _put "$VELO_S_BOOTMODE"; return 0 ;;
	esac
	_vrb=$(velo_detect_bootmode)
	case "$_vrb" in
	uefi|bios) _put "$_vrb"; return 0 ;;
	*)         _put unknown; return 1 ;;
	esac
}

# velo_fdisk_args MODE -- the SINGLE source of truth for fdisk's table-init
# arguments, called by BOTH plan_crypto (preview) and velo_run_crypto (real) so
# the two can never drift (lesson C6/Ворота-4).  uefi -> GPT + 960-sector EFI
# Sys partition; bios -> plain MBR (no -g, no -b: a GPT disk is not legacy-
# bootable, and -b under -i would carve a useless 0xEF EFI slot out of the MBR).
# Unknown/bad mode -> nonzero + empty (so the real path STOPS).
velo_fdisk_args() {
	case "$1" in
	uefi)   _put "-iy -g -b 960"; return 0 ;;
	bios)   _put "-iy"; return 0 ;;
	hybrid) _put "-iy"; return 0 ;;  # step 1 only: A6@64 whole-disk; step 2 = velo_fdisk_hybrid_esp
	*)      return 1 ;;
	esac
}

# velo_fdisk_hybrid_esp DISK -- second fdisk step for hybrid mode.  Shrinks the
# existing 0xA6 OpenBSD entry (MBR slot 3, placed by fdisk -iy) to end before a
# 32 MiB 0xEF EFI tail (MBR slot 0), then re-asserts A6 as active.
# Precondition: fdisk -iy has already run (A6@64, bootable, spanning whole disk).
# The 0xEF size (65536 sectors = 32 MiB) is roomy for FAT16 + BOOTX64.EFI.
# UEFI firmware locates the ESP by partition type, not position, so trailing is fine.
velo_fdisk_hybrid_esp() {
	_vfhe_disk=$1
	is_valid_disk "$_vfhe_disk" || return 1
	_vfhe_esp=65536   # 32 MiB in 512-byte sectors
	_vfhe_total=$(disklabel "$_vfhe_disk" 2>/dev/null | \
		sed -n 's/^total sectors: *\([0-9][0-9]*\).*/\1/p')
	[ -n "$_vfhe_total" ] || return 1
	_vfhe_efoff=$((_vfhe_total - _vfhe_esp))
	_vfhe_a6size=$((_vfhe_efoff - 64))
	fdisk -e "$_vfhe_disk" <<FDEOF || return 1
edit 3
A6
n
64
$_vfhe_a6size
edit 0
EF
n
$_vfhe_efoff
$_vfhe_esp
flag 3
write
quit
FDEOF
}

# velo_efifill DISK -- format the 0xEF partition (FAT16) and plant BOOTX64.EFI
# at the UEFI fallback path \EFI\BOOT\BOOTX64.EFI.  Called AFTER `install` while
# /mnt is still populated.  installboot(8) cannot fill an MBR 0xEF partition (its
# -p ESP support is GPT-only), hence the manual fill.
velo_efifill() {
	_vef_disk=$1
	is_valid_disk "$_vef_disk" || return 1
	[ -f /mnt/usr/mdec/BOOTX64.EFI ] || {
		_putln "velo_efifill: /mnt/usr/mdec/BOOTX64.EFI missing" >&2; return 1; }
	_vef_ep=$(disklabel "$_vef_disk" 2>/dev/null | grep ' MSDOS' | \
		sed -n 's/^ *\([a-p]\):.*/\1/p')
	[ -n "$_vef_ep" ] || {
		_putln "velo_efifill: no MSDOS partition found on $_vef_disk" >&2; return 1; }
	newfs_msdos -F 16 /dev/r${_vef_disk}${_vef_ep} || return 1
	mkdir -p /tmp/velo-esp
	mount -t msdos /dev/${_vef_disk}${_vef_ep} /tmp/velo-esp || return 1
	mkdir -p /tmp/velo-esp/efi/boot
	cp /mnt/usr/mdec/BOOTX64.EFI /tmp/velo-esp/efi/boot/bootx64.efi || {
		umount /tmp/velo-esp 2>/dev/null; return 1; }
	sync
	umount /tmp/velo-esp
	return 0
}

# Megabytes zeroed at the head of the TARGET disk before partitioning, so the
# stale MBR/disklabel/softraid metadata of any prior install is gone before
# fdisk/disklabel/bioctl run (2026-06-08 root cause).  SINGLE SOURCE for both the
# plan_crypto preview and the real velo_run_crypto, like velo_fdisk_args -- the two
# dd lines must never drift in size.  8 MiB covers velo's deepest offset (a@1024
# sectors) ~15x.  Override for tests.
VELO_WIPE_MIB=${VELO_WIPE_MIB:-8}

# --- plan_crypto DISK : the manual FDE shell sequence (PRINTS only) --------
# Emits the exact, copy-pasteable shell the operator (or M3) runs at the
# ramdisk (S)hell BEFORE `install`, when encryption is requested.  Grounded in
# install.sub:encrypt_root() and FAQ 14.
#
# SAFETY:
#  - The passphrase is delivered via STDIN pipe (print -r -- "$VELO_PASSPHRASE"
#    | bioctl -s), never argv/ps.  In DRY-RUN the literal printed is the STRING
#    "$VELO_PASSPHRASE" (the VARIABLE NAME, not the secret) -- the plan is a
#    template, so the real passphrase is NEVER rendered to stdout/screen.
#  - Every device occurrence is double-quoted.
#  - The CRYPTO sd unit is shown as the placeholder sdN with an explicit
#    comment to read it from `bioctl softraid0` at run time (never hardcode).
#  - DISK is re-validated here; refuses (nonzero, prints nothing) on bad input.
#  - NONE of these commands execute -- the whole body is a single heredoc
#    piped only to stdout (via cat); nothing here runs.
plan_crypto() {
	_pc_disk=$1
	if ! is_valid_disk "$_pc_disk"; then
		return 1
	fi
	# Resolve the firmware target -> fdisk table args via the SHARED
	# velo_fdisk_args (the same helper velo_run_crypto uses, so the printed plan
	# and the real run can't drift).  This is a DRY-RUN PREVIEW: if mode=same and
	# detection can't answer (previewing off the target / host `plan`), fall back
	# to the uefi layout for display and SAY SO -- the real run STOPS instead of
	# guessing.  uefi -> "-iy -g -b 960" (GPT+ESP), bios -> "-iy" (legacy MBR).
	_pc_mode=$(velo_resolve_bootmode)
	case "$_pc_mode" in
	uefi)   _pc_fargs=$(velo_fdisk_args uefi);   _pc_note="# GPT + EFI sys partition (uefi target)" ;;
	bios)   _pc_fargs=$(velo_fdisk_args bios);   _pc_note="# legacy MBR, active OpenBSD partition (bios target)" ;;
	hybrid) _pc_fargs=$(velo_fdisk_args hybrid); _pc_note="# hybrid MBR step 1: A6@64 active (step 2 adds 0xEF EFI tail)" ;;
	*)      _pc_mode=uefi; _pc_fargs=$(velo_fdisk_args uefi)
	        _pc_note="# boot mode auto-detected at run time -- preview assumes uefi" ;;
	esac
	# UNQUOTED delimiter (<<PLAN) ON PURPOSE: the validated, double-quoted
	# ${_pc_disk} must expand to splice the device into the template.  The
	# passphrase is protected NOT by quoting the heredoc but by emitting it as
	# the escaped literal \$VELO_PASSPHRASE (a variable NAME in the output text),
	# so the secret's VALUE is never referenced and never rendered.  The inner
	# disklabel heredoc uses a QUOTED <<'EOF', so its body stays literal.
	# ${_pc_fargs}/${_pc_note} are internal, charset-controlled enum-derived
	# strings (velo_fdisk_args), never operator input -- no injection seam.
	cat <<PLAN
# velo: planned full-disk-encryption setup (DRY-RUN -- NOT executed)
# Run these at the bsd.rd (S)hell BEFORE 'install'. Device: ${_pc_disk}
dd if=/dev/zero of="/dev/r${_pc_disk}c" bs=1m count=${VELO_WIPE_MIB}   # blank stale MBR/label/softraid
fdisk ${_pc_fargs} "${_pc_disk}"                  ${_pc_note}
disklabel -E "${_pc_disk}" <<'EOF'                 # one RAID slice 'a'
a
a


RAID
w
q
EOF
print -r -- "\$VELO_PASSPHRASE" | \\
    bioctl -Cforce -cC -l"${_pc_disk}a" -s softraid0   # create CRYPTO volume
# The CRYPTO volume attaches as the NEXT free sd unit. Read it back here,
# NEVER hardcode it:    bioctl softraid0   ->   parse the 'sd<N>' reported.
dd if=/dev/zero of="/dev/rsdNc" bs=1m count=1      # wipe first MB of new vol
PLAN
	# hybrid: append step 2 (fdisk -e to shrink A6 + add 0xEF ESP).
	# velo runs velo_fdisk_hybrid_esp automatically; shown here for operator reference.
	if [ "$_pc_mode" = "hybrid" ]; then
		cat <<'PLAN2'
# hybrid step 2 (run immediately after step 1, before disklabel):
# velo computes ESP offset from total sectors at run time.  Reference only:
# fdisk -e DISK  -> edit 3 (A6: shrink to end-32MiB), edit 0 (EF: 32MiB tail), flag 3, write
# After install, velo fills the EFI partition: newfs_msdos -F 16 + BOOTX64.EFI
PLAN2
	fi
	return 0
}

# --- gen_install_conf : the response file (PRINTS only) --------------------
# Pure function of the VELO_S_* state globals -> stdout.  Emits canonical
# `question = answer` lines (autoinstall(8) substring-match format).  Every
# interpolated answer is charset-restricted upstream (hostname/disk validated,
# profile/startmode enum), so no '=' or newline can split a line; we still
# sanitise the root-disk and hostname through is_valid_disk/valid_hostname
# fallbacks so a malformed state can never inject a line.
gen_install_conf() {
	# Sanitise interpolated answers; substitute an obvious placeholder if a
	# value somehow failed validation (defence in depth -- no injection).
	_gic_host=$VELO_S_HOSTNAME
	valid_hostname "$_gic_host" || _gic_host="velo-bsd"

	_gic_root=$VELO_S_ROOTDISK
	# ROOTDISK is either a validated raw disk (encrypt=no) or the crypto
	# placeholder "sdN" (encrypt=yes). Accept those two shapes ONLY; anything
	# else (e.g. a hostile state value) collapses to the safe "sdN" placeholder
	# so a bad value can never inject a line.
	if [ "$_gic_root" != "sdN" ] && ! is_valid_disk "$_gic_root"; then
		_gic_root="sdN"
	fi

	# Set selection tuned per profile (logical token; refined at M3 in the VM).
	case "$VELO_S_PROFILE" in
	minimal)  _gic_sets="+* -game* -xbase* -xfont* -xserv* -xshare*" ;;
	fortress) _gic_sets="+* -game*" ;;
	*)        _gic_sets="+* -game*" ;;   # homely/default keep x11
	esac

	# Set-location answers (the four install.sub prompts after "Location of sets =
	# disk").  MEDIADISK is the runtime-detected velo USB; sanitise it EXACTLY like
	# _gic_root -- a value that is neither the "sdN" placeholder nor a valid disk
	# collapses to "sdN", so the DRY-RUN preview (where detection has not run, so
	# MEDIADISK is empty) shows a sane token and no hostile state can split a line.
	# PART is one disklabel letter; PATH is charset-restricted (no '=', space or
	# newline), so neither can inject a second response line.
	_gic_media=$VELO_S_MEDIADISK
	if [ "$_gic_media" != "sdN" ] && ! is_valid_disk "$_gic_media"; then
		_gic_media="sdN"
	fi
	_gic_mpart=$VELO_S_MEDIAPART
	case "$_gic_mpart" in [a-p]) : ;; *) _gic_mpart="a" ;; esac
	_gic_mpath=$VELO_S_MEDIAPATH
	case "$_gic_mpath" in ''|*[!A-Za-z0-9./_-]*) _gic_mpath="7.9/amd64" ;; esac

	# Emit in the installer's own question order so a human reading it against
	# a real install sees the prompts in sequence.
	_putln "# ---- velo-generated install.conf (DRY-RUN preview) ----"
	_putln "# profile=${VELO_S_PROFILE:-?} startmode=${VELO_S_STARTMODE:-?} encrypt=${VELO_S_ENCRYPT}"
	_putln "System hostname = ${_gic_host}"
	# Wired-ethernet network config (installer order: net comes right after the
	# hostname, before the root password).  WITHOUT these lines configure_ifs()
	# falls to its default first interface `(get_ifs netboot; get_ifs) | sed q`,
	# which on a laptop is the Wi-Fi `iwm0` -- and iwm0 has no firmware in bsd.rd,
	# so its autoconf never gets a lease and the unattended install dies (the
	# 2026-06-07 Fujitsu failure).  We pin the WIRED port `em0` (Intel; the
	# common wired NIC on these ThinkPad/Lifebook boxes) to DHCP instead.
	#
	# The interface question is asked in a LOOP and _autorespond() CONSUMES each
	# matched line (it rewrites /tmp/ai/ai.conf, dropping the line it used), so
	# the SAME key appears TWICE here -- `em0` is consumed on the first pass
	# (configure that port), `done` on the second (leave the loop).  Order
	# matters: em0 MUST precede done.  With a single DHCP-managed interface the
	# installer auto-fills the default route and DNS from the lease and asks NO
	# further network questions (v4_defroute/donetconfig short-circuit), so there
	# is nothing left to answer and no "Default IPv4 route?" prompt to hang on.
	# All four values are constant literals -- no interpolation, no injection.
	_putln "Network interface to configure = em0"
	_putln "IPv4 address for em0 = autoconf"
	_putln "IPv6 address for em0 = none"
	_putln "Network interface to configure = done"
	# Passwords: an EMPTY hash global -> the <bcrypt-hash> placeholder, so the
	# DRY-RUN/`plan`/on-screen audit-preview carry NO credential.  velo_execute
	# sets these globals to the real bcrypt hashes (encrypt(1)) ONLY for the
	# 0600 /tmp install.conf the installer reads -- never to the screen.  The
	# installer's encr_pwd() recognises the $2b$.. hash and uses it verbatim.
	_putln "Password for root = ${VELO_S_ROOTPW_HASH:-<bcrypt-hash>}"
	_putln "Change the default console to com0 = no"
	_putln "Setup a user = anon"
	_putln "Full name for user = anon"
	_putln "Password for user = ${VELO_S_USERPW_HASH:-<bcrypt-hash>}"
	_putln "Allow root ssh login = no"
	_putln "What timezone are you in = Europe/Kiev"
	_putln "Which disk is the root disk = ${_gic_root}"
	_putln "Use (A)uto layout = auto"
	_putln "Location of sets = disk"
	# The four set-location follow-ups install.sub asks after "= disk".  EXACT 7.9
	# prompt wording transcribed from the 2026-06-08 Fujitsu console, so the
	# autoinstall substring-match cannot miss.  The disk in lines 2 and 3 is the
	# RUNTIME-DETECTED velo USB (never the sd0 default); the partition is the
	# 4.2BSD set partition (never the wrong MSDOS 'i' default); the path is the
	# already-correct "7.9/amd64".  Without these the install aborts on the wrong
	# disk with "7.9/amd64 does not exist".
	_putln "Is the disk partition already mounted = no"
	_putln "Which disk contains the install media = ${_gic_media}"
	_putln "Which ${_gic_media} partition has the install sets = ${_gic_mpart}"
	_putln "Pathname to the sets = ${_gic_mpath}"
	_putln "Set name(s) = ${_gic_sets}"
	_putln "Continue without verification = yes"
	return 0
}

# Scrub EVERY in-memory secret: FDE passphrase, the transient tui_password slot,
# the root/user plaintext passwords AND their bcrypt hashes.  Called on every exit
# path of the wizard/plan (including an early cancel) so a hostile/careless env that
# pre-seeded VELO_S_ROOTPW/USERPW can never leave plaintext live in the shell.
_velo_scrub_secrets() {
	VELO_S_PASSPHRASE=""
	VELO_PASSWORD=""
	VELO_S_ROOTPW=""; VELO_S_USERPW=""
	VELO_S_ROOTPW_HASH=""; VELO_S_USERPW_HASH=""
	VELO_S_WIFI_PSK=""
}

# ===========================================================================
#  NON-INTERACTIVE DRY-RUN ENTRYPOINT  (`velo-install plan`)
#  Seeds VELO_S_* from same-named env vars (with safe defaults), then prints
#  the install.conf and (if encrypt=yes) the crypto plan.  NEVER calls
#  tui_init / velo_readkey -> pipe-safe, headless, no raw mode, no disk I/O.
# ===========================================================================
velo_plan() {
	# Seed from env with defaults.  We re-validate everything so a hostile env
	# cannot inject anything into the generated files.
	VELO_S_DISK=${VELO_S_DISK:-sd0}
	is_valid_disk "$VELO_S_DISK" || VELO_S_DISK="sd0"

	VELO_S_ENCRYPT=${VELO_S_ENCRYPT:-no}
	case "$VELO_S_ENCRYPT" in yes|no) : ;; *) VELO_S_ENCRYPT="no" ;; esac

	VELO_S_HOSTNAME=${VELO_S_HOSTNAME:-velo-bsd}
	valid_hostname "$VELO_S_HOSTNAME" || VELO_S_HOSTNAME="velo-bsd"

	VELO_S_PROFILE=${VELO_S_PROFILE:-homely}
	case "$VELO_S_PROFILE" in homely|minimal|fortress) : ;; *) VELO_S_PROFILE="homely" ;; esac

	VELO_S_STARTMODE=${VELO_S_STARTMODE:-L1}
	case "$VELO_S_STARTMODE" in L1|L2|L3) : ;; *) VELO_S_STARTMODE="L1" ;; esac

	VELO_S_BOOTMODE=${VELO_S_BOOTMODE:-same}
	case "$VELO_S_BOOTMODE" in same|uefi|bios|hybrid) : ;; *) VELO_S_BOOTMODE="same" ;; esac

	# Set-location PART/PATH (DRY-RUN preview re-validates everything).  MEDIADISK
	# is intentionally NOT resolved here: velo_plan does NO disk I/O, so detection
	# runs only on the real velo_execute path; gen_install_conf shows the "sdN"
	# placeholder for the disk in the preview.
	VELO_S_MEDIAPART=${VELO_S_MEDIAPART:-a}
	case "$VELO_S_MEDIAPART" in [a-p]) : ;; *) VELO_S_MEDIAPART="a" ;; esac
	VELO_S_MEDIAPATH=${VELO_S_MEDIAPATH:-7.9/amd64}
	case "$VELO_S_MEDIAPATH" in ''|*[!A-Za-z0-9./_-]*) VELO_S_MEDIAPATH="7.9/amd64" ;; esac

	VELO_S_PKGS=${VELO_S_PKGS:-$(profile_pkgs "$VELO_S_PROFILE")}

	# Derive the root disk: raw disk for plaintext, crypto placeholder for FDE.
	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		VELO_S_ROOTDISK="sdN"
	else
		VELO_S_ROOTDISK="$VELO_S_DISK"
	fi

	# Collapse the newline-separated disk list to a single line WITHOUT `tr`
	# (absent in the ramdisk): unquoted re-expansion word-splits on IFS and
	# `set --` rejoins with single spaces.
	_vp_disks=$(velo_list_disks)
	set -- $_vp_disks
	_vp_disks_line="$*"

	_putln "=== velo DRY-RUN plan (nothing is written to disk) ==="
	_putln ""
	_putln "Detected disks: $_vp_disks_line"
	_putln "Chosen disk:    $VELO_S_DISK"
	_putln "Encryption:     $VELO_S_ENCRYPT"
	_putln "Hostname:       $VELO_S_HOSTNAME"
	_putln "Profile:        $VELO_S_PROFILE"
	_putln "Packages (M2):  $VELO_S_PKGS"
	_putln "Protection:     $VELO_S_STARTMODE"
	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		_putln "Boot mode:      $VELO_S_BOOTMODE"
	fi
	_putln ""

	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		_putln "--- planned full-disk-encryption shell sequence ---"
		plan_crypto "$VELO_S_DISK"
		_putln ""
	fi

	_putln "--- generated install.conf ---"
	gen_install_conf

	# Hygiene: secrets are never used in `plan` mode, but clear them anyway.
	_velo_scrub_secrets
	return 0
}

# ===========================================================================
#  DISK IDENTITY (TUI-SAFE) -- enrich the picker / summary / destroy-gate so the
#  operator sees name + size + type + DUID + markers, never a bare sdN.  Every
#  field is BEST-EFFORT and FAILS to "unknown" (never a guess): the only always-
#  reliable field is the name (hw.disknames).  Ramdisk-only tools: disklabel
#  (read-only, no -E), dmesg/cat, mount, sed + ksh case/$(( )).  NO awk/tr/printf/
#  head/od/df.  velo_disk_row is the SINGLE identity composer reused by all three
#  screens, so they cannot drift (same discipline as velo_fdisk_args for fdisk).
# ===========================================================================

# Upper size bound for the install-media [media?] tag.  NOTE: disklabel reports
# the PHYSICAL medium size, not the ~1.34 GiB image dd'd onto it -- a 32 GB stick
# reads as ~30 GiB (2026-06-08 Fujitsu metal: the 30 GB velo USB blew past the old
# 8 GiB bound, so velo_find_media_disk saw ZERO media and aborted "could not
# uniquely identify the velo install medium").  128 GiB comfortably covers real
# USB install sticks while staying under typical internal/external SSD targets, so
# the soft picker tag still tells stick from target at a glance.  This is now ONLY
# the picker's hint + a sanity ceiling: the SAFETY-critical selector
# velo_find_media_disk ALSO excludes the chosen install target, so a large disk
# that happens to carry a velo image can never be mistaken for the medium even if
# it slips under this bound.  The real fingerprint is the layout TRIPLE below
# (a:4.2BSD@1024 + i:MSDOS960@64).  Override for tests.
# NB: keep this >= the largest install stick you use (raise in lockstep if you
# adopt bigger media; and with build/grow-media.sh if the IMAGE itself grows huge).
VELO_MEDIA_MAX_BYTES=${VELO_MEDIA_MAX_BYTES:-137438953472}   # 128 GiB

# The homely desktop closure needs materially more room than a base/minimal
# install.  A 16 GiB live run exhausted /usr and /usr/local, then left the target
# inconsistent on the next boot.  Refuse homely targets below 28 GiB before the
# typed destroy gate; an unknown size is also a refusal, never a guess.
VELO_HOMELY_MIN_BYTES=30064771072   # 28 GiB

# velo_disk_probe DISK -- run `disklabel DISK` ONCE (read-only, no -E) and stash
# size / sector-size / DUID / raw-label in globals (_VDP_*).  Any field that is
# absent or non-numeric -> "" (unknown); disklabel missing/failed -> all "".  The
# rd makes /dev nodes on demand, so MAKEDEV first (as velo_run_crypto does); the
# read-only disklabel never alters the disk.
velo_disk_probe() {
	_vdp_disk=$1
	_VDP_SECT=""; _VDP_BPS=""; _VDP_DUID=""; _VDP_LABEL=""
	is_valid_disk "$_vdp_disk" || return 1
	( cd /dev && sh MAKEDEV "$_vdp_disk" ) 2>/dev/null || true
	_VDP_LABEL=$(disklabel "$_vdp_disk" 2>/dev/null) || _VDP_LABEL=""
	[ -n "$_VDP_LABEL" ] || return 1
	# Single-occurrence fields -> plain sed, no head (absent in the rd).
	_VDP_BPS=$(_put "$_VDP_LABEL"  | sed -n 's/^bytes\/sector: *\([0-9]*\).*/\1/p')
	_VDP_SECT=$(_put "$_VDP_LABEL" | sed -n 's/^total sectors: *\([0-9]*\).*/\1/p')
	_VDP_DUID=$(_put "$_VDP_LABEL" | sed -n 's/^duid: *\([0-9a-f]*\).*/\1/p')
	case "$_VDP_BPS"  in ''|*[!0-9]*) _VDP_BPS="" ;; esac
	case "$_VDP_SECT" in ''|*[!0-9]*) _VDP_SECT="" ;; esac
	return 0
}

# velo_profile_target_size_ok DISK PROFILE -- profile-specific capacity gate.
# minimal/fortress keep their existing behaviour.  homely requires a readable
# disklabel size of at least VELO_HOMELY_MIN_BYTES.  Leaves _VDP_* populated so
# the caller can report the detected size without probing the disk again.
velo_profile_target_size_ok() {
	_vptso_disk=$1
	_vptso_profile=$2
	[ "$_vptso_profile" = homely ] || return 0
	velo_disk_probe "$_vptso_disk" || return 1
	case "$_VDP_SECT" in ''|*[!0-9]*) return 1 ;; esac
	case "$_VDP_BPS"  in ''|*[!0-9]*) return 1 ;; esac
	[ "$_VDP_SECT" -gt 0 ] && [ "$_VDP_BPS" -gt 0 ] || return 1
	[ $(( _VDP_SECT * _VDP_BPS )) -ge "$VELO_HOMELY_MIN_BYTES" ]
}

# velo_human_size BYTES -> e.g. "16.0G" (GiB, binary).  Pure ksh integer math (no
# printf/float): pick T/G/M/K, tenths = BYTES*10/unit.  ""/0/non-numeric -> "?".
velo_human_size() {
	_vhs_b=$1
	case "$_vhs_b" in ''|*[!0-9]*) _put "?"; return 0 ;; esac
	[ "$_vhs_b" -gt 0 ] || { _put "?"; return 0; }
	if   [ "$_vhs_b" -ge 1099511627776 ]; then _vhs_u=1099511627776; _vhs_s=T
	elif [ "$_vhs_b" -ge 1073741824 ];    then _vhs_u=1073741824;    _vhs_s=G
	elif [ "$_vhs_b" -ge 1048576 ];       then _vhs_u=1048576;       _vhs_s=M
	else                                        _vhs_u=1024;         _vhs_s=K
	fi
	_vhs_t=$(( _vhs_b * 10 / _vhs_u ))
	_put "$(( _vhs_t / 10 )).$(( _vhs_t % 10 ))$_vhs_s"
}

# velo_disk_duid_disp -- DUID for display from _VDP_DUID (set by velo_disk_probe);
# empty / all-zero -> "(none)".  Caller truncates to the column width.
velo_disk_duid_disp() {
	case "$_VDP_DUID" in
	''|0000000000000000) _put "(none)"; return 0 ;;
	esac
	_put "$_VDP_DUID"
}

# velo_disk_type DISK -- short class hint from the boot dmesg (BEST-EFFORT; the
# attach line may be absent at install time -> "" -> rendered "unknown").  Reads
# /var/run/dmesg.boot (as velo_detect_bootmode), falling back to live `dmesg`.
velo_disk_type() {
	_vdt_disk=$1
	if [ -r /var/run/dmesg.boot ]; then
		_vdt_dmesg=$(cat /var/run/dmesg.boot 2>/dev/null)
	elif command -v dmesg >/dev/null 2>&1; then
		_vdt_dmesg=$(dmesg 2>/dev/null)
	else
		_vdt_dmesg=""
	fi
	[ -n "$_vdt_dmesg" ] || { _put ""; return 0; }
	# First attach line for this disk; `q` after the first match avoids head.
	_vdt_line=$(_put "$_vdt_dmesg" | sed -n "/^${_vdt_disk} at /{p;q;}")
	[ -n "$_vdt_line" ] || { _put ""; return 0; }
	_vdt_rem=0
	case "$_vdt_line" in *" removable"*) _vdt_rem=1 ;; esac
	# umass (USB) iff this disk's scsibus is "at umass" elsewhere in the dmesg.
	_vdt_bus=$(_put "$_vdt_line" | sed -n 's/.* at \(scsibus[0-9]*\) .*/\1/p')
	_vdt_umass=0
	if [ -n "$_vdt_bus" ] && _put "$_vdt_dmesg" | grep -q "^${_vdt_bus} at umass"; then
		_vdt_umass=1
	fi
	if   [ "$_vdt_umass" = 1 ] && [ "$_vdt_rem" = 1 ]; then _put "umass/removable"
	elif [ "$_vdt_umass" = 1 ];                        then _put "umass"
	elif [ "$_vdt_rem" = 1 ];                          then _put "removable"
	else                                                    _put "internal"
	fi
}

# velo_disk_is_media -- 0 iff _VDP_LABEL matches velo's OWN install-media layout
# (build/grow-media.sh): disklabel 'a' = 4.2BSD at offset 1024 AND 'i' = MSDOS
# size 960 offset 64 AND total < VELO_MEDIA_MAX_BYTES.  STRICT TRIPLE on purpose:
# an ESP alone is not unique (a UEFI target carries one too), so all three marks
# must hold -> a real, large, RAID-sliced target cannot false-match.  Consumes
# the _VDP_* globals from the velo_disk_probe call that velo_disk_row makes first.
velo_disk_is_media() {
	[ -n "$_VDP_LABEL" ] || return 1
	case "$_VDP_SECT" in ''|*[!0-9]*) return 1 ;; esac
	_vim_bps=$_VDP_BPS; case "$_vim_bps" in ''|*[!0-9]*) _vim_bps=512 ;; esac
	[ $(( _VDP_SECT * _vim_bps )) -lt "$VELO_MEDIA_MAX_BYTES" ] || return 1
	_vim_a=0; _vim_i=0
	while read -r _vim_p _vim_sz _vim_off _vim_fs _vim_rest; do
		case "$_vim_p" in
		a:) [ "$_vim_off" = 1024 ] && [ "$_vim_fs" = 4.2BSD ] && _vim_a=1 ;;
		i:) [ "$_vim_sz" = 960 ] && [ "$_vim_off" = 64 ] && [ "$_vim_fs" = MSDOS ] && _vim_i=1 ;;
		esac
	done <<EOF
$_VDP_LABEL
EOF
	[ "$_vim_a" = 1 ] && [ "$_vim_i" = 1 ]
}

# velo_disk_row DISK -- the SINGLE enriched identity line, reused by the picker,
# the summary and the destroy-gate so the three can never drift.  Columns
# name(5) size(7) type(15) duid(6) + " [MOUNTED]"/" [media?]" markers; worst case
# 55 chars -> fits the menu label (VELO_BOX_W-5 = 59) and the boxes' 62-col body.
velo_disk_row() {
	_vdr_disk=$1
	velo_disk_probe "$_vdr_disk"        # sets _VDP_*; rc ignored (fields -> "")
	if [ -n "$_VDP_SECT" ]; then
		_vdr_bps=$_VDP_BPS; case "$_vdr_bps" in ''|*[!0-9]*) _vdr_bps=512 ;; esac
		_vdr_size=$(velo_human_size $(( _VDP_SECT * _vdr_bps )))
	else
		_vdr_size="?"
	fi
	_vdr_type=$(velo_disk_type "$_vdr_disk")
	[ -n "$_vdr_type" ] || _vdr_type="unknown"
	_vdr_duid=$(velo_disk_duid_disp)
	case "$_vdr_duid" in
	"(none)") : ;;
	*) _vdr_duid=$(_substr "$_vdr_duid" 0 6) ;;
	esac
	_vdr_mark=""
	if velo_disk_busy "$_vdr_disk";  then _vdr_mark="$_vdr_mark [MOUNTED]"; fi
	if velo_disk_is_media; then _vdr_mark="$_vdr_mark [media?]"; fi
	_put "$(_pad "$_vdr_disk" 5) $(_pad "$_vdr_size" 7) $(_pad "$_vdr_type" 15) $(_pad "$_vdr_duid" 6)$_vdr_mark"
}

# velo_find_media_disk -- print the SINGLE attached disk that IS the velo install
# medium (it carries the sets at 7.9/amd64), identified by its OWN disklabel
# signature via velo_disk_is_media -- NEVER by sd-unit number, which is
# enumeration-order-dependent and differs per machine (the 2026-06-08 Fujitsu
# metal failure: the velo USB was not sd0, so the unanswered set-location prompts
# defaulted to the wrong disk -> "7.9/amd64 does not exist").  FAIL-CLOSED: prints
# nothing and returns nonzero unless EXACTLY ONE disk matches -- zero = stick
# absent/unreadable, more-than-one = a second stick or a dd clone.  Same
# STOP-not-guess discipline as velo_resolve_bootmode / velo_run_crypto.  Reuses
# velo_list_disks (injectable via VELO_FAKE_DISKS), velo_disk_probe and
# velo_disk_is_media, so this runtime selector and the picker's [media?] tag can
# never diverge.  Optional arg $1 = a disk to EXCLUDE (the chosen install target),
# so the medium is never confused with a target that carries a stale velo image.
velo_find_media_disk() {
	_vfmd_exclude=${1:-}        # the chosen install TARGET, if any: never the medium
	_vfmd_match=""
	_vfmd_n=0
	for _vfmd_d in $(velo_list_disks); do
		# Skip the disk we are about to ERASE: a large target that still carries an
		# old velo image (2026-06-08: the 232 GiB Samsung held the prior 'gospel'
		# write) would otherwise be a second layout match -> ambiguous, or under a
		# generous size bound could win outright.  The medium is never the target.
		[ -n "$_vfmd_exclude" ] && [ "$_vfmd_d" = "$_vfmd_exclude" ] && continue
		velo_disk_probe "$_vfmd_d" || continue   # sets _VDP_*; skip unreadable
		if velo_disk_is_media; then
			_vfmd_match=$_vfmd_d
			_vfmd_n=$(( _vfmd_n + 1 ))
		fi
	done
	[ "$_vfmd_n" = 1 ] || return 1
	_put "$_vfmd_match"
}

# ===========================================================================
#  INTERACTIVE WIZARD  (8 screens + summary; a conditional boot-mode screen
#  appears between start-mode and summary ONLY for an encrypted install)
#  Uses ONLY the velo-tui.ksh widgets.  Each screen sets exactly one datum.
#  ESC steps back; the summary's "No" steps back to screen 1 to revise; "Yes"
#  prints the plan (still DRY-RUN -- nothing is written).
# ===========================================================================

# screen layout constants
VELO_BOX_X=4
VELO_BOX_Y=3
VELO_BOX_W=64

# Fixed footer row for the help-line.  It sits BELOW the deepest widget any
# screen can draw: the disk menu caps at 12 items (box bottom border at row
# VELO_BOX_Y+12+1 = 16) and the summary box is 13 rows (rows 3..15).  Row 18
# leaves a one-row gap under all of them and still fits a 24-row vt220 console.
# Because every widget's read-loop repaints ONLY its own interior rows (never
# below its bottom border), a footer drawn here -- even BEFORE a blocking
# menu/radio/checklist -- is never overwritten.  This is why the help-line needs
# NO change to velo-tui.ksh's widget layer.
VELO_HELP_Y=18

# _wiz_help CONTEXT [sizes] -- draw the unified footer hint below the current
# screen's widget.  CONTEXT is the Esc semantics ("back" on mid screens, "stock
# installer" on welcome, "abort" on the destroy gate).  Pass a non-empty 2nd arg
# on screens that show a disk SIZE to append the GiB unit reminder.  Plain panel
# colour, ASCII only; widest line ("...Esc=abort  sizes in GiB" = 37) is well
# under the 61-col body budget.
_wiz_help() {
	_wh_ctx=$1
	_wh_line="Enter=select  Esc=$_wh_ctx"
	if [ -n "${2:-}" ]; then
		_wh_line="$_wh_line  sizes in GiB"
	fi
	_text_at $((VELO_BOX_X + 2)) "$VELO_HELP_Y" "$_wh_line"
}

_wiz_welcome() {
