# Summary / Ворота-СТОП.  Returns 0 = Yes (print plan), 1 = No (revise).
_wiz_summary() {
	velo_clear
	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		_ws_enc="yes (passphrase set)"
		case "$VELO_S_BOOTMODE" in
		same)   _ws_boot="same (auto-detect at run time)" ;;
		uefi)   _ws_boot="uefi (GPT + EFI system partition)" ;;
		bios)   _ws_boot="bios (legacy MBR)" ;;
		hybrid) _ws_boot="hybrid (MBR + EFI tail -- legacy and UEFI)" ;;
		*)      _ws_boot="$VELO_S_BOOTMODE" ;;
		esac
	else
		_ws_enc="no"
		_ws_boot="(installer default; FDE only)"
	fi
	tui_box "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" 14 "Summary -- review before planning (FINAL GATE)"
	# disk: uses the SHORT 6-col "disk: " prefix (NOT the 12-col label grid) and is
	# NEVER clipped -- matching the destroy-gate, it keeps the enriched identity
	# within the 61-col body with zero slip (worst-case row 55 + 6 = 61), so the
	# trailing [MOUNTED]/[media?] safety markers can never be truncated on this
	# point-of-no-return review screen.  Label misalignment is the accepted cost
	# of never cutting the safety signal (review finding B1).
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 1)) "disk: $(velo_disk_row "$VELO_S_DISK")"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 2)) "encryption: $_ws_enc"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 3)) "boot:       $_ws_boot"
	# hostname reaches ~50 chars (tui_input cap) or 63 (env-seeded) -> clip to the
	# 61-col body exactly like packages below, so a long name cannot wrap onto the
	# wifi: row.  (profile/protection are short enums -- no clip needed.)
	_ws_host="$VELO_S_HOSTNAME"
	[ ${#_ws_host} -gt 49 ] && _ws_host="$(_substr "$_ws_host" 0 45) ..."
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 4)) "hostname:   $_ws_host"
	_ws_wifi="${VELO_S_WIFI_SSID:-(skipped)}"
	[ ${#_ws_wifi} -gt 49 ] && _ws_wifi="$(_substr "$_ws_wifi" 0 45) ..."
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 5)) "wifi:       $_ws_wifi"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 6)) "profile:    $VELO_S_PROFILE"
	# Clip the (long, firefox-profile) package list to the 61-col body so it cannot
	# wrap onto and corrupt the rows below (2026-06-08: 14 pkgs overran into the
	# protection line).  "packages:   " is 12 cols -> 49 left; ASCII ellipsis.  The
	# FULL list still lands in /etc/velo/answers + the post-install summary.
	_ws_pkgs="${VELO_S_PKGS:-(none)}"
	if [ ${#_ws_pkgs} -gt 49 ]; then
		_ws_pkgs="$(_substr "$_ws_pkgs" 0 45) ..."
	fi
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 7)) "packages:   $_ws_pkgs"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 8)) "protection: $VELO_S_STARTMODE"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 9)) "passwords:  set (root, user)"
	# Tell the truth about Yes HERE too (mirrors _wiz_welcome): on armed media Yes
	# proceeds PAST the printed plan to velo_execute's disk-erase gate and the real
	# install; only the unarmed planner merely prints.  velo_armed is the gate.
	if velo_armed; then
		_ws_yes="ARMED: Yes leads to the disk-erase gate -- REAL install."
	else
		_ws_yes="DRY-RUN: choosing Yes only PRINTS the plan."
	fi
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 10)) "$_ws_yes"
	_wiz_help "revise" "sizes"
	tui_confirm "$VELO_BOX_X" $((VELO_BOX_Y + 11)) "$VELO_BOX_W" "Confirm" "Generate the install plan now?"
}

# ===========================================================================
#  M3 DESTRUCTIVE EXECUTE PATH (gated; INERT unless armed by the medium).
#  Reached from velo_wizard's tail AFTER the summary Ворота-СТОП Yes + the plan
#  preview.  TWO independent arming gates before any destructive token:
#    (1) env VELO_ALLOW_EXECUTE=yes -- set ONLY by the ramdisk launcher on the
#        real medium; absent on host/tests/`plan` -> the path is INERT (rc 2).
#    (2) a typed-confirm gate -- operator types the EXACT target disk name;
#        empty/mismatch ABORTS (default-No, m3-requirements).
#  Passphrase ($VELO_S_PASSPHRASE) touches ONLY the bioctl stdin pipe; the caller
#  scrubs it AFTER velo_execute returns.  Mechanism (install.sub source-grounded,
#  docs/m3-design s2.3): `install -a -f FILE` -> non-interactive, NO 5s watchdog,
#  NO auto_install.conf.  Items still FLAGGED `verify in 7.9 VM` per m3-design.
# ===========================================================================

# velo_armed -- 0 iff VELO_ALLOW_EXECUTE=yes; single arming chokepoint.
velo_armed() {
	[ "${VELO_ALLOW_EXECUTE:-no}" = "yes" ]
}

# velo_confirm_destructive DISK -- the typed-exact-name gate (no default path).
velo_confirm_destructive() {
	_vcd_disk=$1
	is_valid_disk "$_vcd_disk" || return 1
	velo_clear
	_vcd_title="!!! DESTROY DISK -- POINT OF NO RETURN !!!"
	tui_box "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" 9 "$_vcd_title"
	# Accent the gate in ANSI red (bold white on red).  tui_box paints the title
	# blue like every screen; over-draw it here in danger colour so the destroy
	# gate is visually unmistakable.  Colour is gated by VELO_USE_COLOR (no-op on
	# a colourless terminal); the ASCII rule below carries the same separation
	# WITHOUT colour, so the gate still reads on a mono console.  The over-draw
	# string MUST match tui_box's " $title " framing (leading + trailing space).
	_goto "$VELO_BOX_Y" $((VELO_BOX_X + 1))
	velo_danger_on; _put " $_vcd_title "; velo_danger_off
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 2)) \
		"This ERASES ALL DATA on $_vcd_disk and installs OpenBSD."
	# "There is NO undo" also in danger colour (manual draw, not _text_at).
	_goto $((VELO_BOX_Y + 3)) $((VELO_BOX_X + 2))
	velo_danger_on; _put "There is NO undo."; velo_danger_off
	velo_panel_on; _put "  Encrypted: ${VELO_S_ENCRYPT}."; velo_reset
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 4)) \
		"disk: $(velo_disk_row "$_vcd_disk")"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 5)) \
		"To proceed, type the disk name EXACTLY:  $_vcd_disk"
	# Always-on ASCII separator (visible without colour); width <= inner (62).
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 6)) \
		"$(_repeat '-' 58)"
	_wiz_help "abort" "sizes"
	tui_input $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 7)) $((VELO_BOX_W - 4)) \
		"disk:" "" || return 1
	[ "$VELO_INPUT" = "$_vcd_disk" ] || return 1
	return 0
}

# velo_crypto_unit -- echo the CRYPTO sd unit from `bioctl softraid0` (NEVER
# hardcoded); nonzero+empty if undeterminable.  Pure case / param-expansion.
velo_crypto_unit() {
	# `bioctl softraid0` prints e.g.:  softraid0 0 Online <size> sd2     CRYPTO
	# The CRYPTO sd unit is a token INSIDE that line (the line's first word is
	# "softraid0").  Capture the output (NO pipe-subshell, so `return` works) and
	# pick the first PURE sd<N> token; is_valid_disk rejects chunk tokens (sd1a).
	_vcu_out=$(bioctl softraid0 2>/dev/null)
	for _vcu_tok in $_vcu_out; do
		case "$_vcu_tok" in
		sd[0-9]*)
			if is_valid_disk "$_vcu_tok"; then _put "$_vcu_tok"; return 0; fi
			;;
		esac
	done
	return 1
}

# velo_disk_busy DISK -- 0 if DISK has any mounted partition (refuse to install
# onto the running medium / a mounted disk).  Defence in depth.
velo_disk_busy() {
	mount 2>/dev/null | grep -q "^/dev/$1[a-p] " && return 0
	return 1
}

# velo_mount_target_partitions DISK -- mount every non-root ffs slice from the
# target fstab under /mnt so the chroot hook sees real /home /var /usr …
# Auto-layout installs split these; writing into an unmounted mountpoint lands
# on the tiny / slice and is hidden once the real slice mounts at first boot.
velo_mount_target_partitions() {
	_vmtp_disk=$1
	_vmtp_fstab=/mnt/etc/fstab
	[ -r "$_vmtp_fstab" ] || return 0
	while IFS= read -r _vmtp_line; do
		case "$_vmtp_line" in
		""|"#"*) continue ;;
		esac
		set -- $_vmtp_line
		_vmtp_spec=$1
		_vmtp_mp=$2
		_vmtp_fst=$3
		[ "$_vmtp_fst" = ffs ] || continue
		[ "$_vmtp_mp" = / ] && continue
		case "$_vmtp_spec" in
		*.*) _vmtp_letter=${_vmtp_spec##*.} ;;
		*) continue ;;
		esac
		_vmtp_dev="/dev/${_vmtp_disk}${_vmtp_letter}"
		_vmtp_mntp="/mnt${_vmtp_mp}"
		if mount 2>/dev/null | grep -q " on ${_vmtp_mntp} "; then
			_putln "velo: ${_vmtp_mp} already mounted (chroot layout)"
			continue
		fi
		fsck -p "$_vmtp_dev" >/dev/null 2>&1 || true
		mkdir -p "$_vmtp_mntp" 2>/dev/null || true
		if mount "$_vmtp_dev" "$_vmtp_mntp" 2>/dev/null; then
			_putln "velo: mounted $_vmtp_dev on $_vmtp_mntp (chroot layout)"
		else
			_putln "velo: WARN mount $_vmtp_dev on $_vmtp_mntp failed" >&2
		fi
	done < "$_vmtp_fstab"
}

# velo_umount_target_partitions -- unmount /mnt and every slice mounted under it.
velo_umount_target_partitions() {
	_vutp_i=0
	while [ $_vutp_i -lt 12 ]; do
		_vutp_any=0
		if [ -r /mnt/etc/fstab ]; then
			while IFS= read -r _vutp_line; do
				case "$_vutp_line" in
				""|"#"*) continue ;;
				esac
				set -- $_vutp_line
				_vutp_mp=$2
				_vutp_fst=$3
				[ "$_vutp_fst" = ffs ] || continue
				[ "$_vutp_mp" = / ] && continue
				if umount "/mnt${_vutp_mp}" 2>/dev/null; then
					_vutp_any=1
				fi
			done < /mnt/etc/fstab
		fi
		[ $_vutp_any -eq 1 ] || break
		_vutp_i=$((_vutp_i + 1))
	done
	umount /mnt 2>/dev/null || true
}

# velo_run_crypto DISK -- the REAL plan_crypto sequence; echoes the CRYPTO sd
# unit on stdout; nonzero on any failure.  Passphrase piped to bioctl STDIN ONLY.
# Re-asserts the arming gate (rc 3) so a mis-ordered call still cannot fire.
velo_run_crypto() {
	set +x                      # defensive: never xtrace the passphrase pipe
	_vrc_disk=$1
	velo_armed                  || return 3
	is_valid_disk "$_vrc_disk"  || return 1
	[ -n "$VELO_S_PASSPHRASE" ] || return 1
	# The rd knows the disk (hw.disknames) but makes /dev nodes ON DEMAND; create
	# the chunk disk's nodes before fdisk/disklabel/bioctl touch it.  MAKEDEV is
	# in /dev in the install ramdisk.
	( cd /dev && sh MAKEDEV "$_vrc_disk" ) 2>/dev/null || true
	# Resolve the firmware target and pick fdisk's table args via the SAME helper
	# plan_crypto previews (anti-drift).  On the real medium `same` MUST detect --
	# an unresolved boot mode is a fail-safe STOP (return 1), never a guess.
	# velo_fdisk_args returns nonzero for an unknown/bad mode, so the `||` aborts
	# BEFORE any destructive fdisk runs.  _vrc_fargs is an internal enum-derived
	# string ("-iy -g -b 960" | "-iy"); the deliberate unquoted expansion below
	# word-splits it into fdisk flags (no operator input, no metachars).
	_vrc_mode=$(velo_resolve_bootmode)
	_vrc_fargs=$(velo_fdisk_args "$_vrc_mode") || {
		_putln "velo: ERROR -- cannot determine boot mode ('$_vrc_mode'); refusing to partition $_vrc_disk." >&2
		return 1
	}
	# Zero the target's first 8 MiB so fdisk/disklabel/bioctl start from a TRUE
	# blank slate.  A disk that already carries a velo/OpenBSD layout keeps its
	# partition 'a'; then `disklabel -E ... a a` below reports "Partition 'a' is in
	# use", the RAID slice is never laid, and bioctl aborts "softraid0: invalid
	# metadata format" (2026-06-08 Fujitsu metal: sd2 still held the old 'gospel'
	# image).  8 MiB clears the MBR/GPT-primary + the disklabel + the softraid
	# metadata at the chunk head.  /dev/r<disk>c is the whole-disk raw node MAKEDEV
	# made above.  FAIL CLOSED: if we cannot wipe, do NOT partition.
	dd if=/dev/zero of="/dev/r${_vrc_disk}c" bs=1m count=$VELO_WIPE_MIB >/dev/null 2>&1 || return 1
	# shellcheck disable=SC2086
	fdisk $_vrc_fargs "$_vrc_disk"                     || return 1
	# hybrid: shrink A6 and add 0xEF EFI tail (step 2; step 1 = fdisk -iy above).
	if [ "$_vrc_mode" = "hybrid" ]; then
		velo_fdisk_hybrid_esp "$_vrc_disk"             || return 1
	fi
	disklabel -E "$_vrc_disk" <<'EOF'                  || return 1
a
a


RAID
w
q
EOF
	print -r -- "$VELO_S_PASSPHRASE" | \
		bioctl -Cforce -cC -l"${_vrc_disk}a" -s softraid0   || return 1
	_vrc_unit=$(velo_crypto_unit) || return 1
	is_valid_disk "$_vrc_unit"    || return 1
	( cd /dev && sh MAKEDEV "$_vrc_unit" ) 2>/dev/null || true
	dd if=/dev/zero of="/dev/r${_vrc_unit}c" bs=1m count=1 >/dev/null 2>&1 \
		|| return 1
	# Return the unit via a GLOBAL, NOT stdout: fdisk/disklabel/bioctl above print
	# to stdout (visible progress), so a $() capture would mix that noise with the
	# unit.  velo_execute reads VELO_CRYPTO_UNIT.
	VELO_CRYPTO_UNIT=$_vrc_unit
	return 0
}

# velo_execute -- the gated real-install driver.  rc: 0 ok, 2 INERT, 1 abort/fail.
velo_execute() {
	if ! velo_armed; then
		_putln "velo: NOT armed (VELO_ALLOW_EXECUTE!=yes) -- refusing to write." >&2
		return 2
	fi
	if [ "$VELO_S_BOOTMODE" = "hybrid" ] && [ "$VELO_S_ENCRYPT" != "yes" ]; then
		_putln "velo: ERROR -- hybrid boot mode requires FDE (encrypt=yes)." >&2
		return 1
	fi
	if velo_disk_busy "$VELO_S_DISK"; then
		_putln "velo: REFUSING -- $VELO_S_DISK has mounted partitions (the medium?)." >&2
		return 1
	fi
	if ! velo_profile_target_size_ok "$VELO_S_DISK" "$VELO_S_PROFILE"; then
		if [ -n "${_VDP_SECT:-}" ] && [ -n "${_VDP_BPS:-}" ]; then
			_vx_target_size=$(velo_human_size $(( _VDP_SECT * _VDP_BPS )))
		else
			_vx_target_size="unknown"
		fi
		_putln "velo: REFUSING -- homely requires a target of at least 28 GiB." >&2
		_putln "velo: detected size for $VELO_S_DISK: $_vx_target_size; nothing was written." >&2
		return 1
	fi
	# ----- PRE-FLIGHT (all read-only): every check that CAN fail must run BEFORE
	# the typed destroy-gate and the irreversible wipe, so a missing medium / empty
	# password / non-oksh runtime / target-is-the-stick aborts while the TARGET IS
	# STILL INTACT.  Until 2026-06-11 these ran AFTER velo_run_crypto, so "could not
	# uniquely identify the velo install medium" was only discovered once the target
	# had already been wiped and encrypted -- a direct violation of velo's own
	# "fail-closed BEFORE anything irreversible" rule (it bit the 2026-06-08 run).
	# Hashing happens here too (pure, no disk writes): a weird encrypt(1) failure
	# then also aborts pre-wipe instead of leaving a half-built, encrypted target.
	set +x
	# Fail closed if `print` is not a builtin (non-oksh runtime): the hashing pipe
	# below would feed encrypt(1) an EMPTY stdin, and encrypt would happily return a
	# valid $2b$.. hash OF THE EMPTY STRING -- passing the bcrypt guard yet shipping a
	# trivially-weak credential.  The real target (the bsd.rd /bin/ksh) has it; bail
	# anywhere it does not rather than risk a silent empty-password install.
	if [ "${VELO_HAS_PRINT:-0}" != 1 ]; then
		_putln "velo: ERROR -- 'print' builtin unavailable; refusing to hash passwords." >&2
		return 1
	fi
	if [ -z "$VELO_S_ROOTPW" ] || [ -z "$VELO_S_USERPW" ]; then
		_putln "velo: ERROR -- root/user password not set; refusing to install." >&2
		return 1
	fi
	# Refuse if the chosen TARGET is itself the velo install medium: erasing the
	# only installer stick would kill the source mid-run, and velo_find_media_disk
	# (which excludes the target) would then see ZERO media and abort with the
	# misleading "is the stick inserted?".  Say it plainly instead -- the picker's
	# soft [media?] tag is cosmetic; this is the hard stop.  The probe's rc is
	# IGNORED on purpose (fail-open here is sound): an unreadable target probes to
	# empty _VDP_* -> is_media false -> guard passes, and an unreadable disk cannot
	# be the medium anyway; do not "fix" this into a fail-closed.
	velo_disk_probe "$VELO_S_DISK"
	if velo_disk_is_media; then
		_putln "velo: REFUSING -- $VELO_S_DISK looks like the velo install medium itself." >&2
		_putln "velo: pick a DIFFERENT target; never install onto the installer stick." >&2
		_putln "velo: (a STALE/cloned velo stick you MEAN to overwrite trips this too --" >&2
		_putln "velo:  zero its first MB from the shell first: dd if=/dev/zero of=/dev/rsdNc bs=1m count=1)" >&2
		return 1
	fi
	# Resolve WHICH attached disk is the velo install medium (it carries the sets
	# at 7.9/amd64), so gen_install_conf can pin the disk/partition/path.  The
	# sd-unit is enumeration-order-dependent -- on a laptop the USB is rarely sd0
	# (internal disk + install target shuffle the numbering: the 2026-06-08 Fujitsu
	# run had sd0=internal Linux disk, so the unanswered set-location prompts
	# defaulted to sd0/i and the install aborted "7.9/amd64 does not exist").
	# Fingerprint the medium by its own disklabel signature; FAIL CLOSED if not unique.
	VELO_S_MEDIADISK=$(velo_find_media_disk "$VELO_S_DISK") || {
		_putln "velo: ERROR -- could not uniquely identify the velo install medium." >&2
		_putln "velo: need EXACTLY ONE attached disk matching the medium signature." >&2
		_putln "velo: (is the stick inserted?  is there a second/cloned velo stick?)  Aborting." >&2
		return 1
	}
	if ! is_valid_disk "$VELO_S_MEDIADISK"; then
		_putln "velo: ERROR -- media detection returned an invalid disk name; aborting." >&2
		return 1
	fi
	# Hash the operator's root/user passwords with encrypt(1) -- present in the rd
	# (the stock installer uses it too).  Secret hygiene mirrors the bioctl
	# passphrase pipe (velo_run_crypto): plaintext flows VARIABLE -> `print` builtin
	# (no fork, no argv) -> pipe -> encrypt STDIN; only the HASH is captured in
	# $(...).  `-b a` = auto-rounds, exactly as the stock installer's encr_pwd().
	VELO_S_ROOTPW_HASH=$(print -r -- "$VELO_S_ROOTPW" | encrypt -b a)
	VELO_S_USERPW_HASH=$(print -r -- "$VELO_S_USERPW" | encrypt -b a)
	# The installer's encr_pwd() takes a $2b$.. hash verbatim (no double-encrypt);
	# refuse to write a response file unless BOTH look like real bcrypt hashes.
	_vx_ok=yes
	case "$VELO_S_ROOTPW_HASH" in '$2'*) : ;; *) _vx_ok=no ;; esac
	case "$VELO_S_USERPW_HASH" in '$2'*) : ;; *) _vx_ok=no ;; esac
	if [ "$_vx_ok" != yes ]; then
		_putln "velo: ERROR -- encrypt(1) did not produce bcrypt hashes; aborting." >&2
		VELO_S_ROOTPW_HASH=""; VELO_S_USERPW_HASH=""; return 1
	fi
	# ----- TYPED DESTROY-GATE: the LAST human checkpoint, now with every precondition
	# already proven.  Nothing below this line until velo_run_crypto is recoverable.
	if ! velo_confirm_destructive "$VELO_S_DISK"; then
		velo_clear
		_putln "velo: destructive confirmation failed/cancelled -- aborted."
		return 1
	fi
	velo_clear
	# TOCTOU belt: the operator can dwell at the gate indefinitely, and a USB
	# hiccup/re-enumeration there leaves VELO_S_MEDIADISK pointing at a stale
	# sd-unit that would only fail AFTER the wipe -- the exact failure class the
	# pre-flight exists to prevent.  Re-probe the pinned medium NOW, still
	# pre-wipe; abort if it no longer answers with the medium signature.
	velo_disk_probe "$VELO_S_MEDIADISK"
	if ! velo_disk_is_media; then
		_putln "velo: ERROR -- install medium $VELO_S_MEDIADISK vanished/changed while waiting at the gate." >&2
		_putln "velo: nothing was written; re-seat the stick and retry." >&2
		return 1
	fi
	_putln "velo: ARMED + confirmed -- real install on $VELO_S_DISK."
	_putln "velo: install medium = $VELO_S_MEDIADISK (sets at ${VELO_S_MEDIAPART}:${VELO_S_MEDIAPATH})"
	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		_putln "velo: creating softraid CRYPTO volume ..."
		VELO_CRYPTO_UNIT=""
		velo_run_crypto "$VELO_S_DISK"
		if [ $? -ne 0 ] || [ -z "$VELO_CRYPTO_UNIT" ]; then
			_putln "velo: ERROR -- crypto setup failed (target $VELO_S_DISK is now PARTIALLY WIPED); aborting." >&2
			return 1
		fi
		VELO_S_ROOTDISK=$VELO_CRYPTO_UNIT
		_putln "velo: CRYPTO root = $VELO_S_ROOTDISK (from bioctl softraid0)."
	else
		VELO_S_ROOTDISK=$VELO_S_DISK
	fi
	_vx_rf=/tmp/velo-install.conf
	# gen_install_conf now emits the REAL hashes (globals set just above) into this
	# file ONLY.  The on-screen audit-preview (velo_wizard / velo_plan) ran earlier
	# with the globals still empty, so it showed the <bcrypt-hash> placeholder -- no
	# credential, hashed or otherwise, ever reaches the screen.  Create the file
	# 0600 FROM THE START via a subshell umask (a post-write chmod would leave a
	# brief world-readable window on the hashes); rm any pre-existing path first so a
	# planted symlink cannot redirect the hash write.  Trailing chmod is belt-and-braces.
	rm -f "$_vx_rf" 2>/dev/null || true
	if ! ( umask 077; gen_install_conf >"$_vx_rf" ); then
		_putln "velo: ERROR generating install.conf" >&2; return 1
	fi
	chmod 0600 "$_vx_rf" 2>/dev/null || true
	# NON-INTERACTIVE installer: `install -a -f FILE` (install.sub getopts) takes
	# the cp-to-/tmp/ai/ai.conf branch -> do_install with NO 5s watchdog and NO
	# auto_install.conf.  Sets from the medium (Location of sets=disk), verify off,
	# site79.tgz LAST, install.site auto-run at its safe floor.
	_putln "velo: running 'install -af' (non-interactive, no timeout) ..."
	if ! install -a -f "$_vx_rf"; then
		_putln "velo: ERROR -- installer returned non-zero." >&2; return 1
	fi
	# Apply the operator's profile/level.  Write the answers contract (m2-design
	# s2.3) to the new root, then run the velo site hook CHROOTED with those
	# answers present.  The hook ships as install.site.velo (NOT install.site),
	# so the stock installer did NOT auto-run it at the safe floor -- velo runs it
	# exactly once here, with the real profile=$VELO_S_PROFILE / $VELO_S_STARTMODE.
	if mount "/dev/${VELO_S_ROOTDISK}a" /mnt 2>/dev/null || mount | grep -q " on /mnt "; then
		velo_mount_target_partitions "$VELO_S_ROOTDISK"
		mkdir -p /mnt/etc/velo 2>/dev/null
		velo_answers_body >/mnt/etc/velo/answers 2>/dev/null
		chmod 0600 /mnt/etc/velo/answers 2>/dev/null || true
		# Verify the answers contract actually landed -- a silent write failure
		# would make install.site.velo fall back to the safe floor (minimal+L1),
		# losing the operator's profile/level (and, at L3, the fail-closed stack).
		if [ -s /mnt/etc/velo/answers ]; then
			_putln "velo: wrote answers (profile=$VELO_S_PROFILE startmode=$VELO_S_STARTMODE encrypt=$VELO_S_ENCRYPT)"
		else
			_putln "velo: ERROR could not write /mnt/etc/velo/answers -- chosen profile/level LOST; install.site.velo will fall back to the safe floor (minimal+L1)" >&2
		fi
		# Write Wi-Fi credentials directly to hostname.iwm0 (PSK never enters the
		# answers audit file).  install.site.velo's L3/non-desktop prune gates will
		# remove the file if the chosen profile or startmode excludes Wi-Fi.
		if [ -n "$VELO_S_WIFI_SSID" ]; then
			printf 'join "%s" wpakey "%s"\ndhcp\n' \
				"$VELO_S_WIFI_SSID" "$VELO_S_WIFI_PSK" \
				>/mnt/etc/hostname.iwm0 2>/dev/null \
				&& _putln "velo: wrote /mnt/etc/hostname.iwm0 (SSID=$VELO_S_WIFI_SSID PSK=redacted)" \
				|| _putln "velo: WARN could not write /mnt/etc/hostname.iwm0" >&2
		fi
		if [ -x /mnt/install.site.velo ]; then
			_putln "velo: applying profile/level via 'chroot /mnt /install.site.velo' ..."
			chroot /mnt /install.site.velo \
				|| _putln "velo: WARN install.site.velo returned non-zero (see /var/log/velo-install.site.log)" >&2
			rm -f /mnt/install.site.velo 2>/dev/null || true
		else
			_putln "velo: WARN /mnt/install.site.velo missing -- box left at installer defaults" >&2
		fi
		# hybrid: fill the 0xEF EFI partition with BOOTX64.EFI while /mnt is live.
		if [ "$VELO_S_ENCRYPT" = "yes" ] && [ "$VELO_S_BOOTMODE" = "hybrid" ]; then
			_putln "velo: filling EFI system partition (hybrid mode) ..."
			velo_efifill "$VELO_S_DISK" \
				|| _putln "velo: WARN velo_efifill returned non-zero -- UEFI boot may not work." >&2
		fi
		sync; velo_umount_target_partitions
	else
		# mount failed AND nothing is on /mnt: the post-install steps (answers,
		# install.site.velo, hybrid EFI-fill) were ALL skipped.  Do NOT print
		# "install complete" as if nothing happened.  For hybrid the ESP is then
		# empty -> the disk will not boot via UEFI at all, so that case is FATAL.
		_putln "velo: ERROR -- cannot mount /dev/${VELO_S_ROOTDISK}a; profile/answers/EFI-fill SKIPPED." >&2
		if [ "$VELO_S_BOOTMODE" = "hybrid" ]; then
			_putln "velo: hybrid install left an EMPTY ESP -- the box will NOT boot via UEFI" >&2
			_putln "velo: (legacy BIOS boot may still work). FATAL." >&2
			return 1
		fi
		_putln "velo: WARN -- box will boot at INSTALLER DEFAULTS (chosen profile/level NOT applied, rc.firsttime pkg_add will not run)." >&2
		_putln "velo: install finished DEGRADED.  Reboot boots a stock-defaults box (no pkg_add)."
		return 0
	fi
	_putln "velo: install complete.  Reboot to finish (rc.firsttime runs pkg_add)."
	return 0
}

# _wiz_complete -- the post-install "what now" screen, shown ONLY after a
# SUCCESSFUL real install (armed path, velo_execute rc 0).  It replaces the old
# SILENT fall-through to the stock (I)/(U)/(A)/(S) menu, which made a perfect
# install look like a no-op ("it just shows the installer again").  The single
# thing the operator needs next is: power off, REMOVE the velo medium, and boot
# the TARGET disk -- so we say exactly that, then offer to power off now.
#
# Re-enters raw TUI mode (velo_wizard already ran tui_cleanup before printing the
# plan + the install progress); tui_init/tui_cleanup are balanced and re-entrant.
# Declining the power-off returns 0 and the wizard falls through to the stock
# menu/shell exactly as before -- the escape hatch is preserved.  Secrets were
# already consumed by velo_execute; scrub again up-front so nothing lingers
# across the confirm wait or into a No-path shell.  halt(8) lives in the install
# ramdisk; if it is somehow absent (host/tests) the `|| true` falls through.
_wiz_complete() {
	_velo_scrub_secrets
	tui_init
	velo_clear
	tui_box "$VELO_BOX_X" "$VELO_BOX_Y" "$VELO_BOX_W" 11 \
		"INSTALL COMPLETE -- velo is on $VELO_S_DISK"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 1)) \
		"OpenBSD + velo ($VELO_S_HOSTNAME) is installed and bootable."
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 2)) \
		"The FIRST boot finishes setup (pkg_add, fail-closed pf)."
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 4)) "To start using it:"
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 5)) "  1. Power off this machine."
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 6)) "  2. REMOVE the velo install medium (USB / ISO)."
	_text_at $((VELO_BOX_X + 2)) $((VELO_BOX_Y + 7)) "  3. Boot from the target disk ($VELO_S_DISK)."
	_wiz_help "shell"
	tui_confirm "$VELO_BOX_X" $((VELO_BOX_Y + 8)) "$VELO_BOX_W" \
		"Power off" "Power off now?  (No -> stock installer menu / shell)"
	_vc_off=$?
	tui_cleanup
	velo_clear
	if [ "$_vc_off" -eq 0 ]; then
		_putln "velo: powering off -- REMOVE the medium, then boot $VELO_S_DISK."
		sync 2>/dev/null || true
		halt -p 2>/dev/null || halt 2>/dev/null || true
		# halt unavailable (host/tests) -> fall through to the normal return.
	else
		_putln "velo: install complete.  REMOVE the medium and boot $VELO_S_DISK."
		_putln "velo: dropping to the stock OpenBSD installer menu / shell."
	fi
	return 0
}

# Drive all screens with ESC-steps-back navigation.
velo_wizard() {
	tui_init

	_wz_screen=0
	# Total CONFIG-screen count for the "Step k/N" counters.  FIXED at 10 (velo is
	# FDE-first: the boot-mode screen is screen 10, and the disk-erase path even
	# REQUIRES encrypt=yes).  Held constant -- NOT recomputed after the encrypt
	# choice -- so the denominator never changes mid-wizard.  A plaintext install
	# simply skips screen 10 and ends at "9/10" -> summary; the denominator stays
	# put either way.  welcome and the summary FINAL GATE sit OUTSIDE it.
	_wz_total=10
	while :; do
		case "$_wz_screen" in
		0)
			if _wiz_welcome; then _wz_screen=1; else
				tui_cleanup
				velo_clear
				_putln "velo: cancelled."
				_velo_scrub_secrets
				return 1
			fi
			;;
		1) if _wiz_disk;      then _wz_screen=2; else _wz_screen=0; fi ;;
		2)
			if _wiz_encrypt; then _wz_screen=3; else _wz_screen=1; fi
			;;
		3) if _wiz_rootpw;    then _wz_screen=4; else _wz_screen=2; fi ;;
		4) if _wiz_userpw;    then _wz_screen=5; else _wz_screen=3; fi ;;
		5) if _wiz_hostname;  then _wz_screen=6; else _wz_screen=4; fi ;;
		6) if _wiz_wifi;      then _wz_screen=7; else _wz_screen=5; fi ;;
		7) if _wiz_profile;   then _wz_screen=8; else _wz_screen=6; fi ;;
		8) if _wiz_packages;  then _wz_screen=9; else _wz_screen=7; fi ;;
		9) if _wiz_startmode; then _wz_screen=10; else _wz_screen=8; fi ;;
		10)
			# Boot/firmware target -- FDE only.  A plaintext install skips
			# straight to the summary (the stock installer lays out its disk);
			# only an encrypted install reaches _wiz_bootmode, where ESC steps
			# back to start mode.
			if [ "$VELO_S_ENCRYPT" = "yes" ]; then
				if _wiz_bootmode; then _wz_screen=11; else _wz_screen=9; fi
			else
				_wz_screen=11
			fi
			;;
		11)
			if _wiz_summary; then
				break          # Yes -> build & print the plan
			else
				_wz_screen=1   # No -> revise from screen 1
			fi
			;;
		esac
	done

	# Derive the root disk now that all data is collected.
	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		VELO_S_ROOTDISK="sdN"
	else
		VELO_S_ROOTDISK="$VELO_S_DISK"
	fi

	tui_cleanup
	velo_clear

	# Build & print the plan (AUDIT PREVIEW, shown even on real media).
	# plan_crypto prints the VARIABLE NAME, not the secret; gen_install_conf
	# carries no secret.
	_putln "=== velo install plan ==="
	_putln ""
	if [ "$VELO_S_ENCRYPT" = "yes" ]; then
		_putln "--- planned full-disk-encryption shell sequence ---"
		plan_crypto "$VELO_S_DISK"
		_putln ""
	fi
	_putln "--- generated install.conf ---"
	gen_install_conf
	_putln ""
	_putln "Packages recorded for M2 (installed post-reboot): ${VELO_S_PKGS:-(none)}"
	_putln ""

	# GATED REAL EXECUTE (M3 s2.3).  INERT unless armed: on host / tests /
	# `plan` mode VELO_ALLOW_EXECUTE is unset, so velo_execute returns 2 and
	# writes NOTHING -- the plan above is then the whole output, identical to the
	# M1 DRY-RUN.  On the real medium the launcher arms it; velo_execute runs the
	# typed-confirm gate then the real install.  The passphrase is consumed INSIDE
	# velo_execute (velo_run_crypto), so the scrub MUST stay AFTER this call.
	if velo_armed; then
		velo_execute; _vw_rc=$?
		# Success -> the post-install "what now" screen (power off / remove medium
		# / boot the target).  This is the ONE place that tells the operator the
		# install is DONE and how to use it, instead of silently re-showing the
		# stock (I)/(U)/(A)/(S) menu.  rc 1 (abort/fail) keeps the plain message;
		# rc 2 (inert) cannot occur here -- we are inside the armed branch.
		if [ "$_vw_rc" -eq 0 ]; then
			_wiz_complete
		elif [ "$_vw_rc" -eq 1 ]; then
			_putln "velo: install aborted or failed."
		fi
	else
		_putln "velo: DRY-RUN only (not armed) -- nothing was written to disk."
	fi

	# Scrub the secrets now that crypto setup + install consumed them (or we were
	# inert).  Covers the FDE passphrase AND the root/user passwords + their hashes.
	_velo_scrub_secrets
	return 0
}

# ===========================================================================
#  SELFTEST  (pure-function assertions; runs under bash AND oksh, no tty)
# ===========================================================================
velo_selftest() {
	_st_fail=0
	_st_n=0

	# assert_eq LABEL EXPECTED ACTUAL
	assert_eq() {
		_st_n=$((_st_n + 1))
		if [ "$2" = "$3" ]; then
			_putln "ok   $1"
		else
			_putln "FAIL $1"
			_putln "       expected: [$2]"
			_putln "       actual:   [$3]"
			_st_fail=$((_st_fail + 1))
		fi
	}
	# assert_rc LABEL EXPECTED_RC ACTUAL_RC
	assert_rc() {
		_st_n=$((_st_n + 1))
		if [ "$2" = "$3" ]; then
			_putln "ok   $1"
		else
			_putln "FAIL $1 (rc expected $2 got $3)"
			_st_fail=$((_st_fail + 1))
		fi
	}
	# assert_has LABEL HAYSTACK NEEDLE
	assert_has() {
		_st_n=$((_st_n + 1))
		case "$2" in
		*"$3"*) _putln "ok   $1" ;;
		*) _putln "FAIL $1 (missing substring: [$3])"; _st_fail=$((_st_fail + 1)) ;;
		esac
	}
	# assert_hasnt LABEL HAYSTACK NEEDLE
	assert_hasnt() {
		_st_n=$((_st_n + 1))
		case "$2" in
		*"$3"*) _putln "FAIL $1 (UNEXPECTED substring: [$3])"; _st_fail=$((_st_fail + 1)) ;;
		*) _putln "ok   $1" ;;
		esac
	}

	# --- 1. is_valid_disk -------------------------------------------------
	is_valid_disk sd0;  assert_rc "is_valid_disk sd0"  0 $?
	is_valid_disk wd12; assert_rc "is_valid_disk wd12" 0 $?
	is_valid_disk cd0;  assert_rc "is_valid_disk cd0 reject"  1 $?
	is_valid_disk sd;   assert_rc "is_valid_disk sd reject"   1 $?
	is_valid_disk sd0x; assert_rc "is_valid_disk sd0x reject" 1 $?
	is_valid_disk xsd0; assert_rc "is_valid_disk xsd0 reject" 1 $?
	is_valid_disk "";   assert_rc "is_valid_disk empty reject" 1 $?
	is_valid_disk "sd0; rm -rf /"; assert_rc "is_valid_disk injection reject" 1 $?

	# --- 2. velo_list_disks (injected) ------------------------------------
	_st_list=$(VELO_FAKE_DISKS='sd0:a,cd0:,wd1:b,rd0:,sd2' velo_list_disks)
	# normalise newlines to spaces for comparison
	_st_list_sp=$(VELO_FAKE_DISKS='sd0:a,cd0:,wd1:b,rd0:,sd2' velo_list_disks | while IFS= read -r _l; do _put "$_l "; done)
	assert_eq "velo_list_disks drops cd/rd, strips DUIDs, keeps order" "sd0 wd1 sd2 " "$_st_list_sp"

	# --- 3. idx_to_disk over that list ------------------------------------
	VELO_FAKE_DISKS='sd0:a,cd0:,wd1:b,rd0:,sd2'
	assert_eq "idx_to_disk 0" "sd0" "$(idx_to_disk 0)"
	assert_eq "idx_to_disk 1" "wd1" "$(idx_to_disk 1)"
	assert_eq "idx_to_disk 2" "sd2" "$(idx_to_disk 2)"
	idx_to_disk 3 >/dev/null; assert_rc "idx_to_disk 3 out-of-range" 1 $?
	assert_eq "idx_to_disk 3 empty" "" "$(idx_to_disk 3)"
	unset VELO_FAKE_DISKS

	# --- index->label for profile/startmode -------------------------------
	assert_eq "idx_to_profile 0"   "homely"   "$(idx_to_profile 0)"
	assert_eq "idx_to_profile 2"   "fortress" "$(idx_to_profile 2)"
	assert_eq "idx_to_startmode 0" "L1"       "$(idx_to_startmode 0)"
	assert_eq "idx_to_startmode 2" "L3"       "$(idx_to_startmode 2)"

	# --- idxset_to_pkgs (checklist re-index) ------------------------------
	assert_eq "idxset_to_pkgs maps checked indices" "git tmux vim" \
		"$(idxset_to_pkgs '0 2 3' git curl tmux vim)"
	assert_eq "idxset_to_pkgs empty selection" "" \
		"$(idxset_to_pkgs '' git curl tmux vim)"

	# --- 4. valid_hostname ------------------------------------------------
	valid_hostname "velo-bsd"; assert_rc "valid_hostname velo-bsd" 0 $?
	valid_hostname "-bad";     assert_rc "valid_hostname -bad reject" 1 $?
	valid_hostname "bad-";     assert_rc "valid_hostname bad- reject" 1 $?
	valid_hostname "a.b";      assert_rc "valid_hostname a.b reject" 1 $?
	valid_hostname "a b";      assert_rc "valid_hostname 'a b' reject" 1 $?
	valid_hostname "";         assert_rc "valid_hostname empty reject" 1 $?
	# 63-char label ok, 64 rejected
	_st_h63="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
	valid_hostname "$_st_h63";   assert_rc "valid_hostname 63-char ok"  0 $?
	valid_hostname "${_st_h63}a"; assert_rc "valid_hostname 64-char reject" 1 $?

	# --- 5. profile_pkgs --------------------------------------------------
	assert_eq "profile_pkgs minimal" "git curl nano" "$(profile_pkgs minimal)"
	assert_has "profile_pkgs homely has openbox" "$(profile_pkgs homely)" "openbox"
	assert_has "profile_pkgs homely has terminator" "$(profile_pkgs homely)" "terminator"
	assert_has "profile_pkgs homely has noto-fonts" "$(profile_pkgs homely)" "noto-fonts"
	assert_has "profile_pkgs fortress has tor" "$(profile_pkgs fortress)" "tor"
	profile_pkgs bogus >/dev/null; assert_rc "profile_pkgs unknown nonzero" 1 $?
	assert_eq "profile_pkgs unknown empty" "" "$(profile_pkgs bogus)"

	# --- 6. gen_install_conf (encrypt=no) ---------------------------------
	VELO_S_ENCRYPT="no"; VELO_S_DISK="sd0"; VELO_S_ROOTDISK="sd0"
	VELO_S_HOSTNAME="velo-bsd"; VELO_S_PROFILE="homely"; VELO_S_STARTMODE="L1"
	VELO_S_PASSPHRASE="TOPSECRET-PASS"
	_st_conf=$(gen_install_conf)
	assert_has "conf has root disk sd0" "$_st_conf" "Which disk is the root disk = sd0"
	assert_has "conf has hostname"       "$_st_conf" "System hostname = velo-bsd"
	assert_has "conf has verify-off"     "$_st_conf" "Continue without verification = yes"
	# wired-ethernet block: em0/dhcp pinned, iwm0 never reached (2026-06-07 fix).
	# Two interface lines (em0 then done) -- _autorespond consumes one per pass.
	assert_has "conf picks em0 iface"    "$_st_conf" "Network interface to configure = em0"
	assert_has "conf em0 is dhcp"        "$_st_conf" "IPv4 address for em0 = autoconf"
	assert_has "conf em0 no ipv6"        "$_st_conf" "IPv6 address for em0 = none"
	assert_has "conf iface loop done"    "$_st_conf" "Network interface to configure = done"
	assert_hasnt "conf never names iwm0" "$_st_conf" "iwm0"
	assert_hasnt "conf no passphrase"    "$_st_conf" "TOPSECRET-PASS"
	assert_hasnt "conf no bioctl"        "$_st_conf" "bioctl"

	# --- 7. gen_install_conf (encrypt=yes -> crypto placeholder) ----------
	VELO_S_ENCRYPT="yes"; VELO_S_ROOTDISK="sdN"
	_st_conf2=$(gen_install_conf)
	assert_has "conf(yes) root disk = sdN" "$_st_conf2" "Which disk is the root disk = sdN"
	assert_hasnt "conf(yes) no passphrase" "$_st_conf2" "TOPSECRET-PASS"

	# injection guard: a malformed hostname in state must not split a line.
	VELO_S_HOSTNAME="evil = boom"
	_st_conf3=$(gen_install_conf)
	assert_has "conf sanitises bad hostname" "$_st_conf3" "System hostname = velo-bsd"
	assert_hasnt "conf bad hostname not injected" "$_st_conf3" "evil = boom"
	VELO_S_HOSTNAME="velo-bsd"

	# --- 7b. password hash globals (placeholder vs real) ------------------
	# Empty hash globals -> the <bcrypt-hash> placeholder (DRY-RUN/plan/preview
	# carry NO credential).
	VELO_S_ROOTPW_HASH=""; VELO_S_USERPW_HASH=""
	_st_cph=$(gen_install_conf)
	assert_has "conf placeholder root (no hash)" "$_st_cph" "Password for root = <bcrypt-hash>"
	assert_has "conf placeholder user (no hash)" "$_st_cph" "Password for user = <bcrypt-hash>"
	# Set hash globals (the velo_execute path) -> the real hash is emitted.
	VELO_S_ROOTPW_HASH='$2b$10$ROOThashROOThashROOThashROOThashROOThashRO'
	VELO_S_USERPW_HASH='$2b$10$USERhashUSERhashUSERhashUSERhashUSERhashUS'
	_st_cph2=$(gen_install_conf)
	assert_has "conf emits root hash"  "$_st_cph2" 'Password for root = $2b$10$ROOThash'
	assert_has "conf emits user hash"  "$_st_cph2" 'Password for user = $2b$10$USERhash'
	assert_hasnt "conf no placeholder when hashed" "$_st_cph2" "<bcrypt-hash>"
	VELO_S_ROOTPW_HASH=""; VELO_S_USERPW_HASH=""

	# --- 7c. plaintext passwords NEVER leak into install.conf -------------
	VELO_S_ROOTPW="PLAINTEXT-ROOT-PW"; VELO_S_USERPW="PLAINTEXT-USER-PW"
	_st_cpl=$(gen_install_conf)
	assert_hasnt "conf no plaintext root pw" "$_st_cpl" "PLAINTEXT-ROOT-PW"
	assert_hasnt "conf no plaintext user pw" "$_st_cpl" "PLAINTEXT-USER-PW"
	VELO_S_ROOTPW=""; VELO_S_USERPW=""

	# --- 8. plan_crypto ---------------------------------------------------
	VELO_S_PASSPHRASE="TOPSECRET-PASS"
	_st_pc=$(plan_crypto sd0)
	assert_rc "plan_crypto sd0 rc" 0 $?
	assert_has "plan_crypto bioctl line"  "$_st_pc" 'bioctl -Cforce -cC -l"sd0a" -s softraid0'
	assert_has "plan_crypto stdin pipe (var name)" "$_st_pc" 'print -r -- "$VELO_PASSPHRASE" |'
	assert_has "plan_crypto fdisk quoted disk" "$_st_pc" 'fdisk -iy -g -b 960 "sd0"'
	assert_has "plan_crypto target pre-wipe"   "$_st_pc" 'dd if=/dev/zero of="/dev/rsd0c" bs=1m count=8'
	assert_has "plan_crypto dd wipe quoted"    "$_st_pc" 'dd if=/dev/zero of="/dev/rsdNc" bs=1m count=1'
	assert_hasnt "plan_crypto no real secret"  "$_st_pc" "TOPSECRET-PASS"
	# bad input -> nonzero, prints nothing
	_st_pcbad=$(plan_crypto cd0); _st_pcbad_rc=$?
	assert_rc "plan_crypto cd0 nonzero" 1 "$_st_pcbad_rc"
	assert_eq "plan_crypto cd0 prints nothing" "" "$_st_pcbad"
	_st_pcinj=$(plan_crypto "sd0; rm -rf /"); _st_pcinj_rc=$?
	assert_rc "plan_crypto injection nonzero" 1 "$_st_pcinj_rc"
	assert_eq "plan_crypto injection prints nothing" "" "$_st_pcinj"

	# --- 8b. boot-mode: fdisk args (single source of truth) / detect / -----
	#         resolve / anti-drift preview ----------------------------------
	assert_eq "fdisk_args uefi -> GPT+ESP" "-iy -g -b 960" "$(velo_fdisk_args uefi)"
	assert_eq "fdisk_args bios -> MBR"     "-iy"           "$(velo_fdisk_args bios)"
	velo_fdisk_args same    >/dev/null; assert_rc "fdisk_args same not effective"  1 $?
	velo_fdisk_args unknown >/dev/null; assert_rc "fdisk_args unknown nonzero"     1 $?
	velo_fdisk_args ""      >/dev/null; assert_rc "fdisk_args empty nonzero"       1 $?
	assert_eq "detect honours override uefi" "uefi" "$(VELO_BOOTMODE_DETECT=uefi velo_detect_bootmode)"
	assert_eq "detect honours override bios" "bios" "$(VELO_BOOTMODE_DETECT=bios velo_detect_bootmode)"
	VELO_S_BOOTMODE=uefi
	assert_eq "resolve: explicit uefi wins over detect" "uefi" "$(VELO_BOOTMODE_DETECT=bios velo_resolve_bootmode)"
	VELO_S_BOOTMODE=bios
	assert_eq "resolve: explicit bios" "bios" "$(velo_resolve_bootmode)"
	VELO_S_BOOTMODE=same
	assert_eq "resolve: same -> detect uefi" "uefi" "$(VELO_BOOTMODE_DETECT=uefi velo_resolve_bootmode)"
	assert_eq "resolve: same -> detect bios" "bios" "$(VELO_BOOTMODE_DETECT=bios velo_resolve_bootmode)"
	VELO_BOOTMODE_DETECT=unknown velo_resolve_bootmode >/dev/null
	assert_rc "resolve: same + unknown -> STOP (rc1)" 1 $?
	assert_eq "resolve: same + unknown echoes unknown" "unknown" "$(VELO_BOOTMODE_DETECT=unknown velo_resolve_bootmode)"
	# plan_crypto reflects the resolved mode (preview can't drift from the real
	# run -- both route through velo_fdisk_args):
	VELO_S_BOOTMODE=uefi; _st_pcu=$(plan_crypto sd0)
	assert_has "plan_crypto uefi -> GPT fdisk"  "$_st_pcu" 'fdisk -iy -g -b 960 "sd0"'
	VELO_S_BOOTMODE=bios; _st_pcb=$(plan_crypto sd0)
	assert_has  "plan_crypto bios -> MBR fdisk"  "$_st_pcb" 'fdisk -iy "sd0"'
	assert_hasnt "plan_crypto bios is not GPT"   "$_st_pcb" 'fdisk -iy -g'
	# same + undetectable (host/off-target preview) -> uefi preview WITH a note;
	# the REAL velo_run_crypto instead STOPs (covered behaviourally by the suite
	# section 8c, which drives velo_run_crypto with fdisk shadowed and asserts it
	# returns 1 without reaching fdisk):
	VELO_S_BOOTMODE=same; _st_pcs=$(VELO_BOOTMODE_DETECT=unknown plan_crypto sd0)
	assert_has "plan_crypto same/unknown -> uefi preview" "$_st_pcs" 'fdisk -iy -g -b 960 "sd0"'
	assert_has "plan_crypto same/unknown notes run-time detect" "$_st_pcs" 'auto-detected at run time'
	# hybrid mode: fdisk_args -> "-iy" (step 1 only); resolve honours explicit hybrid;
	# plan_crypto shows step-1 fdisk + step-2 reference block; not GPT.
	assert_eq "fdisk_args hybrid -> MBR step1" "-iy" "$(velo_fdisk_args hybrid)"
	VELO_S_BOOTMODE=hybrid
	assert_eq "resolve: explicit hybrid" "hybrid" "$(velo_resolve_bootmode)"
	_st_pch=$(plan_crypto sd0)
	assert_has  "plan_crypto hybrid -> step1 MBR fdisk" "$_st_pch" 'fdisk -iy "sd0"'
	assert_hasnt "plan_crypto hybrid is not GPT"        "$_st_pch" 'fdisk -iy -g'
	assert_has  "plan_crypto hybrid -> step2 note"      "$_st_pch" 'hybrid step 2'
	assert_has  "plan_crypto hybrid -> EFI fill note"   "$_st_pch" 'BOOTX64.EFI'
	VELO_S_BOOTMODE=same                 # restore the default

	# --- 9. confirm-twice mismatch logic (pure) ---------------------------
	# Replicate the wizard's decision predicate as a pure check.
	pass_match() { [ -n "$1" ] && [ "$1" = "$2" ]; }
	pass_match "abc" "abc"; assert_rc "pass_match equal nonempty -> accept" 0 $?
	pass_match "abc" "abd"; assert_rc "pass_match mismatch -> reject"        1 $?
	pass_match "" "";       assert_rc "pass_match empty -> reject"           1 $?

	# --- 8e. velo_efifill / velo_fdisk_hybrid_esp input validation -----------
	# Pure validation paths (no real disk involved):
	#   - bad disk name rejects before any disk I/O (is_valid_disk guard)
	#   - missing /mnt/usr/mdec/BOOTX64.EFI rejects (checked before disklabel)
	velo_efifill cd0 >/dev/null 2>&1; assert_rc "efifill bad disk nonzero" 1 $?
	velo_efifill ""  >/dev/null 2>&1; assert_rc "efifill empty disk nonzero" 1 $?
	# Without /mnt/usr/mdec/BOOTX64.EFI (not present on the test host):
	velo_efifill sd0 >/dev/null 2>&1; assert_rc "efifill missing BOOTX64.EFI nonzero" 1 $?
	velo_fdisk_hybrid_esp cd0 >/dev/null 2>&1; assert_rc "fdisk_hybrid_esp bad disk nonzero" 1 $?
	velo_fdisk_hybrid_esp ""  >/dev/null 2>&1; assert_rc "fdisk_hybrid_esp empty disk nonzero" 1 $?

	# _velo_scrub_secrets clears every secret global (every wizard/plan exit path).
	VELO_S_PASSPHRASE=x; VELO_PASSWORD=x; VELO_S_ROOTPW=x; VELO_S_USERPW=x
	VELO_S_ROOTPW_HASH=x; VELO_S_USERPW_HASH=x
	_velo_scrub_secrets
	assert_eq "scrub clears passphrase" "" "$VELO_S_PASSPHRASE"
	assert_eq "scrub clears rootpw"     "" "$VELO_S_ROOTPW"
	assert_eq "scrub clears userpw"     "" "$VELO_S_USERPW"
	assert_eq "scrub clears roothash"   "" "$VELO_S_ROOTPW_HASH"
	assert_eq "scrub clears userhash"   "" "$VELO_S_USERPW_HASH"

	# --- scrub ------------------------------------------------------------
	VELO_S_PASSPHRASE=""; VELO_PASSWORD=""
	VELO_S_ROOTPW=""; VELO_S_USERPW=""
	VELO_S_ROOTPW_HASH=""; VELO_S_USERPW_HASH=""

	_putln ""
	if [ "$_st_fail" -eq 0 ]; then
		_putln "PASS: all $_st_n assertions passed."
		return 0
	else
		_putln "FAIL: $_st_fail of $_st_n assertions failed."
		return 1
	fi
}

# ===========================================================================
#  DISPATCH
# ===========================================================================
velo_main() {
	case "${1:-}" in
	plan)
		velo_plan
		;;
	selftest)
		velo_selftest
		;;
	""|interactive)
		# Interactive needs a real tty.  If stdin is not a tty, refuse and
		# point at the non-interactive entrypoint (same guard pattern as demo).
		if [ ! -t 0 ]; then
			_putln "velo-install: no tty for the interactive wizard." >&2
			_putln "Use:  velo-install plan      (non-interactive dry-run)" >&2
			_putln "  or: velo-install selftest  (pure-function tests)" >&2
			return 2
		fi
		velo_wizard
		;;
	*)
		_putln "usage: velo-install [plan|selftest|interactive]" >&2
		return 2
		;;
	esac
}

# Only run main when EXECUTED, not when sourced (so the test file can source
# this and call the pure functions directly).  $0 ends in velo-install when
# executed; the test sources it and sets VELO_SOURCED=1 first.
if [ -z "${VELO_SOURCED:-}" ]; then
	velo_main "$@"
fi
