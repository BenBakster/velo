#!/bin/sh
# /usr/local/bin/velo-level -- Switch or show the active protection level (L1/L2/L3)

set -eu

ANSWERS_FILE="${VELO_ROOT:-}/etc/velo/answers"
PF_CONF="${VELO_ROOT:-}/etc/pf.conf"
SYSCTL_CONF="${VELO_ROOT:-}/etc/sysctl.conf"
LOG_FILE="${VELO_ROOT:-}/var/log/velo-level.log"
PF_BACKUP=""
SYSCTL_BACKUP=""
SYSCTL_LIVE_BACKUP=""

_prev_mode="L1"
if [ -f "$ANSWERS_FILE" ]; then
	_prev_mode=$(sed -n 's/^startmode=\(L[1-3]\).*/\1/p' "$ANSWERS_FILE")
	[ -n "$_prev_mode" ] || _prev_mode="L1"
fi
show_status() {
	_mode="L1"
	if [ -f "$ANSWERS_FILE" ]; then
		_mode=$(sed -n 's/^startmode=\(L[1-3]\).*/\1/p' "$ANSWERS_FILE")
		[ -n "$_mode" ] || _mode="L1"
	fi

	echo "velo: protection profile = $_mode"
	
	if [ -f "$PF_CONF" ]; then
		_pf_hash=$(sha256 -q "$PF_CONF" 2>/dev/null || md5 -q "$PF_CONF" 2>/dev/null || echo "unknown")
		_pf_lines=$(wc -l < "$PF_CONF" 2>/dev/null | tr -d ' ')
		echo "velo: pf rules hash = $_pf_hash ($_pf_lines lines)"
	else
		echo "velo: pf rules = missing"
	fi
	
	if [ -n "${VELO_ROOT:-}" ]; then
		echo "velo: tor daemon = disabled (mocked under prefix)"
	elif command -v rcctl >/dev/null 2>&1; then
		if rcctl check tor >/dev/null 2>&1; then
			echo "velo: tor daemon = running"
		elif rcctl ls enabled | grep -q '^tor$'; then
			echo "velo: tor daemon = enabled, not running"
		else
			echo "velo: tor daemon = disabled"
		fi
	else
		echo "velo: tor daemon = (rcctl not available)"
	fi
}

if [ $# -lt 1 ]; then
	echo "Usage: velo-level [L1|L2|L3|status]" >&2
	exit 1
fi

cmd="$1"

if [ "$cmd" = "status" ]; then
	show_status
	exit 0
fi

if [ "$cmd" != "L1" ] && [ "$cmd" != "L2" ] && [ "$cmd" != "L3" ]; then
	echo "Usage: velo-level [L1|L2|L3|status]" >&2
	exit 1
fi

# Root check (skipped if VELO_LEVEL_TEST=1 or when running under fake root)
if [ -z "${VELO_LEVEL_TEST:-}" ] && [ -z "${VELO_ROOT:-}" ] && [ "$(id -u)" -ne 0 ]; then
	echo "Error: root privileges required (run with doas)." >&2
	exit 1
fi

case "$cmd" in
L1) lvl=l1 ;;
L2) lvl=l2 ;;
L3) lvl=l3 ;;
esac

PF_SRC="${VELO_ROOT:-}/etc/velo/pf/pf.${lvl}.conf"
SYSCTL_SRC="${VELO_ROOT:-}/etc/velo/sysctl/sysctl.${lvl}.conf"

_dryrun="${VELO_LEVEL_DRYRUN:-}"

if [ -n "$_dryrun" ]; then
	echo "velo-level: switching to $cmd (dry-run)"
	if [ ! -f "$PF_SRC" ]; then
		echo "Error: pf config $PF_SRC not found." >&2
		exit 1
	fi
	if [ ! -f "$SYSCTL_SRC" ]; then
		echo "Error: sysctl delta $SYSCTL_SRC not found." >&2
		exit 1
	fi
	exit 0
fi

# Helper function for Tor management
set_tor_state() {
	_target_mode="$1"
	if [ -z "${VELO_ROOT:-}" ]; then
		if [ "$_target_mode" = "L3" ]; then
			if [ ! -f /etc/velo/torrc ]; then
				echo "Error: template /etc/velo/torrc is missing." >&2
				return 1
			fi
			# Verify template torrc contains User _tor, DataDirectory /var/tor, and SOCKSPort 127.0.0.1:9050
			if ! grep -q '^[[:space:]]*User[[:space:]][[:space:]]*_tor' /etc/velo/torrc || \
			   ! grep -q '^[[:space:]]*DataDirectory[[:space:]][[:space:]]*/var/tor' /etc/velo/torrc || \
			   ! grep -q '^[[:space:]]*SOCKSPort[[:space:]][[:space:]]*127\.0\.0\.1:9050' /etc/velo/torrc; then
				echo "Error: template /etc/velo/torrc lacks required security/configuration parameters." >&2
				return 1
			fi
			if ! rcctl enable tor; then
				echo "Error: could not enable Tor service." >&2
				return 1
			fi
			if [ -f /etc/tor/torrc ]; then
				if ! grep -q -e '^# /etc/tor/torrc -- velo L3' -e '^# /etc/tor/torrc -- velo' /etc/tor/torrc 2>/dev/null; then
					if [ ! -f /etc/tor/torrc.orig ]; then
						cp /etc/tor/torrc /etc/tor/torrc.orig
					fi
				fi
			fi
			mkdir -p /etc/tor 2>/dev/null || true
			cp /etc/velo/torrc /etc/tor/torrc
			chmod 0644 /etc/tor/torrc
			if rcctl check tor >/dev/null 2>&1; then
				if ! rcctl restart tor; then
					echo "Error: failed to restart Tor." >&2
					return 1
				fi
			else
				if ! rcctl start tor; then
					echo "Error: failed to start Tor." >&2
					return 1
				fi
			fi
			sleep 1
			if ! rcctl check tor >/dev/null 2>&1; then
				echo "Error: Tor daemon is not running after start." >&2
				return 1
			fi
		else
			rcctl stop tor 2>/dev/null || true
			rcctl disable tor 2>/dev/null || true
			if [ -f /etc/tor/torrc.orig ]; then
				mv /etc/tor/torrc.orig /etc/tor/torrc
			elif [ -f /etc/tor/torrc ]; then
				if grep -q -e '^# /etc/tor/torrc -- velo L3' -e '^# /etc/tor/torrc -- velo' /etc/tor/torrc 2>/dev/null; then
					rm -f /etc/tor/torrc
					rmdir /etc/tor 2>/dev/null || true
				fi
			fi
		fi
	else
		# Under prefix/tests: mock tor file management
		if [ "$_target_mode" = "L3" ]; then
			if [ ! -f "${VELO_ROOT:-}/etc/velo/torrc" ]; then
				echo "Error: template ${VELO_ROOT:-}/etc/velo/torrc is missing." >&2
				return 1
			fi
			# Verify template torrc contains User _tor, DataDirectory /var/tor, and SOCKSPort 127.0.0.1:9050
			if ! grep -q '^[[:space:]]*User[[:space:]][[:space:]]*_tor' "${VELO_ROOT:-}/etc/velo/torrc" || \
			   ! grep -q '^[[:space:]]*DataDirectory[[:space:]][[:space:]]*/var/tor' "${VELO_ROOT:-}/etc/velo/torrc" || \
			   ! grep -q '^[[:space:]]*SOCKSPort[[:space:]][[:space:]]*127\.0\.0\.1:9050' "${VELO_ROOT:-}/etc/velo/torrc"; then
				echo "Error: template ${VELO_ROOT:-}/etc/velo/torrc lacks required security/configuration parameters." >&2
				return 1
			fi
			if [ -f "${VELO_ROOT:-}/etc/tor/torrc" ]; then
				if ! grep -q -e '^# /etc/tor/torrc -- velo L3' -e '^# /etc/tor/torrc -- velo' "${VELO_ROOT:-}/etc/tor/torrc" 2>/dev/null; then
					if [ ! -f "${VELO_ROOT:-}/etc/tor/torrc.orig" ]; then
						cp "${VELO_ROOT:-}/etc/tor/torrc" "${VELO_ROOT:-}/etc/tor/torrc.orig"
					fi
				fi
			fi
			mkdir -p "${VELO_ROOT:-}/etc/tor" 2>/dev/null || true
			cp "${VELO_ROOT:-}/etc/velo/torrc" "${VELO_ROOT:-}/etc/tor/torrc"
		else
			if [ -f "${VELO_ROOT:-}/etc/tor/torrc.orig" ]; then
				mv "${VELO_ROOT:-}/etc/tor/torrc.orig" "${VELO_ROOT:-}/etc/tor/torrc"
			elif [ -f "${VELO_ROOT:-}/etc/tor/torrc" ]; then
				if grep -q -e '^# /etc/tor/torrc -- velo L3' -e '^# /etc/tor/torrc -- velo' "${VELO_ROOT:-}/etc/tor/torrc" 2>/dev/null; then
					rm -f "${VELO_ROOT:-}/etc/tor/torrc"
					rmdir "${VELO_ROOT:-}/etc/tor" 2>/dev/null || true
				fi
			fi
		fi
	fi
	return 0
}

cleanup() {
	if [ -n "${PF_BACKUP:-}" ] && [ -f "$PF_BACKUP" ]; then
		rm -f "$PF_BACKUP"
	fi
	if [ -n "${SYSCTL_BACKUP:-}" ] && [ -f "$SYSCTL_BACKUP" ]; then
		rm -f "$SYSCTL_BACKUP"
	fi
	if [ -n "${SYSCTL_LIVE_BACKUP:-}" ] && [ -f "$SYSCTL_LIVE_BACKUP" ]; then
		rm -f "$SYSCTL_LIVE_BACKUP"
	fi
}

do_rollback() {
	# Restore pf.conf
	if [ -n "${PF_BACKUP:-}" ] && [ -f "$PF_BACKUP" ]; then
		cp "$PF_BACKUP" "$PF_CONF"
		chmod 0600 "$PF_CONF"
		if [ -z "${VELO_ROOT:-}" ]; then
			pfctl -f "$PF_CONF" >/dev/null 2>&1
		fi
	fi

	# Restore sysctl.conf
	if [ -n "${SYSCTL_BACKUP:-}" ] && [ -f "$SYSCTL_BACKUP" ]; then
		cp "$SYSCTL_BACKUP" "$SYSCTL_CONF"
	fi

	# Restore live sysctl values
	if [ -z "${VELO_ROOT:-}" ] && [ -n "${SYSCTL_LIVE_BACKUP:-}" ] && [ -f "$SYSCTL_LIVE_BACKUP" ]; then
		while IFS= read -r _line; do
			case "$_line" in
			""|"#"*) continue ;;
			esac
			sysctl "$_line" >/dev/null 2>&1
		done < "$SYSCTL_LIVE_BACKUP"
	fi

	# Restore Tor state
	set_tor_state "$_prev_mode" >/dev/null 2>&1
}

on_sig() {
	trap '' INT TERM
	echo "velo-level: Interrupted! Rolling back changes..." >&2
	do_rollback
	cleanup
	exit 1
}

trap cleanup EXIT
trap on_sig INT TERM

# Pre-flight check: validate pf rules syntax before we do any changes
if [ -z "${VELO_ROOT:-}" ]; then
	if [ -f "$PF_SRC" ]; then
		if ! pfctl -nf "$PF_SRC"; then
			echo "Error: pf configuration test failed for $PF_SRC (-n)." >&2
			exit 1
		fi
	else
		echo "Error: pf source config $PF_SRC missing." >&2
		exit 1
	fi
fi

# Back up current configuration files using mktemp to avoid overwriting admin backups
if [ -f "$PF_CONF" ]; then
	PF_BACKUP=$(mktemp "${TMPDIR:-/tmp}/velo-pf-backup.XXXXXX")
	cp "$PF_CONF" "$PF_BACKUP"
fi
if [ -f "$SYSCTL_CONF" ]; then
	SYSCTL_BACKUP=$(mktemp "${TMPDIR:-/tmp}/velo-sysctl-backup.XXXXXX")
	cp "$SYSCTL_CONF" "$SYSCTL_BACKUP"
fi

set +e
_failed=0

# 1. Update pf.conf
if [ -f "$PF_SRC" ]; then
	cp "$PF_SRC" "$PF_CONF"
	if [ $? -ne 0 ]; then
		echo "Error: failed to copy $PF_SRC to $PF_CONF." >&2
		_failed=1
	else
		chmod 0600 "$PF_CONF"
	fi
else
	echo "Error: pf source config $PF_SRC missing." >&2
	_failed=1
fi

# 2. Update sysctl.conf
if [ $_failed -eq 0 ]; then
	if [ -f "$SYSCTL_SRC" ]; then
		if [ -f "$SYSCTL_CONF" ]; then
			sed '/# --- velo: L. sysctl deltas/,$d' "$SYSCTL_CONF" > "${SYSCTL_CONF}.tmp"
			if [ $? -ne 0 ]; then
				echo "Error: failed to trim $SYSCTL_CONF." >&2
				_failed=1
			else
				mv "${SYSCTL_CONF}.tmp" "$SYSCTL_CONF"
			fi
		fi
		if [ $_failed -eq 0 ]; then
			{
				echo ""
				echo "# --- velo: ${cmd} sysctl deltas (appended by velo-level) ---"
				cat "$SYSCTL_SRC"
			} >> "$SYSCTL_CONF"
			if [ $? -ne 0 ]; then
				echo "Error: failed to append sysctl deltas." >&2
				_failed=1
			fi
		fi

		# Apply sysctl settings live, backup original values, and check for errors
		if [ $_failed -eq 0 ] && [ -z "${VELO_ROOT:-}" ]; then
			SYSCTL_LIVE_BACKUP=$(mktemp "${TMPDIR:-/tmp}/velo-sysctl-rollback.XXXXXX")
			while IFS= read -r _line; do
				case "$_line" in
				""|"#"*) continue ;;
				esac
				_key="${_line%%=*}"

				# Query current value of sysctl
				_prev_val=$(sysctl -n "$_key" 2>/dev/null)
				if [ $? -eq 0 ]; then
					echo "${_key}=${_prev_val}" >> "$SYSCTL_LIVE_BACKUP"
				else
					echo "# ${_key} not readable" >> "$SYSCTL_LIVE_BACKUP"
				fi

				# Apply new value and check for failure
				if ! sysctl "$_line" >/dev/null; then
					echo "Error: failed to set sysctl $_line." >&2
					_failed=1
					break
				fi
			done < "$SYSCTL_SRC"
		fi
	else
		echo "Error: sysctl delta source $SYSCTL_SRC missing." >&2
		_failed=1
	fi
fi

# 3. Tor management
if [ $_failed -eq 0 ]; then
	set_tor_state "$cmd"
	if [ $? -ne 0 ]; then
		echo "Error: Tor management failed." >&2
		_failed=1
	fi
fi

# 4. Load pf rules (only if not under VELO_ROOT)
if [ $_failed -eq 0 ] && [ -z "${VELO_ROOT:-}" ]; then
	if ! pfctl -f "$PF_CONF"; then
		echo "Error: failed to load pf rules." >&2
		_failed=1
	fi
fi

# Rollback if anything failed
if [ $_failed -ne 0 ]; then
	echo "velo-level: switch failed! Rolling back changes..." >&2
	do_rollback
	exit 1
fi

set -e

# 5. Update answers file startmode
if [ -f "$ANSWERS_FILE" ]; then
	sed 's/^startmode=.*/startmode='"$cmd"'/' "$ANSWERS_FILE" > "${ANSWERS_FILE}.tmp"
	mv "${ANSWERS_FILE}.tmp" "$ANSWERS_FILE"
	chmod 0600 "$ANSWERS_FILE"
fi

# 6. Log changes
touch "$LOG_FILE" 2>/dev/null || true
chmod 0640 "$LOG_FILE" 2>/dev/null || true
echo "$(date): switched protection profile to $cmd" >> "$LOG_FILE" 2>/dev/null || true

echo "velo: successfully switched protection profile to $cmd."
